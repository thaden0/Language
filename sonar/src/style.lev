    bool scalarInRanges(int scalar, Array<int> ranges) {
        int low = 0;
        int high = ranges.length() / 2 - 1;
        while (low <= high) {
            int mid = (low + high) / 2;
            int start = ranges[mid * 2];
            int finish = ranges[mid * 2 + 1];
            if (scalar < start) high = mid - 1;
            else if (scalar > finish) low = mid + 1;
            else return true;
        }
        return false;
    }

    int glyphWidth(char c) {
        int scalar = c.code();
        if (scalarInRanges(scalar, wideRanges)) return 2;
        if (widthMode == WidthMode::EastAsian && scalarInRanges(scalar, ambiguousRanges)) return 2;
        return 1;
    }
}
