namespace Sonar {
    public enum Color : int {
        Default = -1, Black = 0, Red, Green, Yellow, Blue, Magenta, Cyan, White,
        BrightBlack, BrightRed, BrightGreen, BrightYellow, BrightBlue,
        BrightMagenta, BrightCyan, BrightWhite
    }
    public enum BorderStyle { NoBorder, Single, Double, Rounded, Heavy, Dashed }
    public enum KeyCode : int {
        Char = 0, Enter, Escape, Tab, BackTab, Backspace, Delete, Insert,
        Up, Down, Left, Right, Home, End, PageUp, PageDown,
        F1, F2, F3, F4, F5, F6, F7, F8, F9, F10, F11, F12
    }
    public enum MouseButton { NoButton, Left, Middle, Right, WheelUp, WheelDown }
    public enum MouseKind { Press, Release, Move, Drag }
    public enum Overflow { Clip, Scroll, Wrap }
    public enum Align { Start, Center, End, Stretch }
    public enum Axis { Horizontal, Vertical }
    public enum Dock { Top, Bottom, Left, Right, Fill }
    public enum WidthMode { Standard, EastAsian }

    struct Style {
        Color fg;
        Color bg;
        int attrs;

        new Style(Color foreground, Color background, int attributes) {
            fg = foreground; bg = background; attrs = attributes;
        }

        Style withFg(Color c) => Style(c, bg, attrs);
        Style withBg(Color c) => Style(fg, c, attrs);
        Style withAttrs(int a) => Style(fg, bg, a);
        Style over(Style base) => Style(
            fg == Color::Default ? base.fg : fg,
            bg == Color::Default ? base.bg : bg,
            mergeAttrs(attrs, base.attrs)
        );
    }

    int mergeAttrs(int a, int b) {
        int result = 0;
        int bit = 1;
        while (bit <= 128) {
            if ((a / bit) % 2 == 1 || (b / bit) % 2 == 1) result = result + bit;
            bit = bit * 2;
        }
        return result;
    }

    WidthMode widthMode = WidthMode::Standard;
    void setWidthMode(WidthMode mode) { widthMode = mode; }

