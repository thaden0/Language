// T11 R-1: no field-type hole exists, so reactive set-views are gated per type
// with `where f.type == "..."`. int / string / bool each get a typed setter.
namespace R {
    attribute Reactive { }
    rule rInt    { match @Reactive on field f in class C : IHost where f.type == "int"    inject `set $f(int v)    { $f = v; this.__ping(); }` at member of C }
    rule rString { match @Reactive on field f in class C : IHost where f.type == "string" inject `set $f(string v) { $f = v; this.__ping(); }` at member of C }
    rule rBool   { match @Reactive on field f in class C : IHost where f.type == "bool"   inject `set $f(bool v)   { $f = v; this.__ping(); }` at member of C }
    interface IHost { void __ping(); }
}
uses R;
class Model : IHost {
    @Reactive int count = 0;
    @Reactive string label = "x";
    @Reactive bool active = false;
    int pings = 0;
    new Model() { }
    void __ping() { pings = pings + 1; }
}
Model m = Model();
m.count = 3;
m.label = "hi";
m.active = true;
console.writeln(m.count.toString() + "/" + m.label + "/" + m.active.toString() + " pings=" + m.pings.toString());
