uses Sonar;

// A recording ILifecycleHost: observes the @Shortcut/@Timer flush that
// __sonarAttach performs, without standing up a real App run loop.
class RecordHost : Sonar::ILifecycleHost {
    Array<string> log = [];
    Array<() => void> shortcutActions = [];
    Array<int> timerActions_ = [];
    Array<() => void> timerCbs = [];
    int nextTok = 1;

    int bindShortcut(string chord, () => void action) {
        int t = nextTok; nextTok = nextTok + 1;
        log = log.add("bind " + chord + "=" + t.toString());
        shortcutActions = shortcutActions.add(action);
        return t;
    }
    void unbindShortcut(int token) { log = log.add("unbind " + token.toString()); }
    int registerTimer(int intervalMs, () => void action) {
        int t = nextTok; nextTok = nextTok + 1;
        log = log.add("timer " + intervalMs.toString() + "=" + t.toString());
        timerCbs = timerCbs.add(action);
        return t;
    }
    void cancelTimer(int token) { log = log.add("canceltimer " + token.toString()); }
    void scheduleFrame() { }

    void fireShortcut(int i) { var a = shortcutActions[i]; a(); }
    void fireTimer(int i) { var a = timerCbs[i]; a(); }
    string dump() { return log.joinToString(","); }
    void reset() { log = []; }
}

// @Shortcut + @Timer + @Validator all on one class.
class Editor : Sonar::Component {
    int saves = 0;
    int ticks = 0;
    string name = "";

    @Sonar::Shortcut("^S") void save() { saves = saves + 1; }
    @Sonar::Timer(250)     void blink() { ticks = ticks + 1; }
    @Sonar::Validator("name required") bool nameOk() => !name.isEmpty();
}

// §5.3 — two attributes on ONE method: both rules fire independently.
class Poller : Sonar::Component {
    int polls = 0;
    @Sonar::Shortcut("^P") @Sonar::Timer(1000) void poll() { polls = polls + 1; }
}

// §5.4 — an inherited @Shortcut method overridden in a derived class:
// the captured `() => this.act()` dispatches on the runtime class, so the
// OVERRIDE runs.
class BaseTool : Sonar::Component {
    string trace = "";
    new BaseTool() { }
    @Sonar::Shortcut("^B") void act() { trace = trace + "base;"; }
}
class DerivedTool : BaseTool {
    new DerivedTool() { BaseTool::BaseTool(); }
    void act() { trace = trace + "derived;"; }
}

// A multi-validator component: intrinsic (IValidatable) is not implemented
// here, so only the attribute list runs; two validators, first failure wins.
class Form : Sonar::Component {
    bool aOk = false;
    bool bOk = false;
    @Sonar::Validator("A failed") bool checkA() => aOk;
    @Sonar::Validator("B failed") bool checkB() => bOk;
}

void main() {
    RecordHost host = RecordHost();
    Sonar::installLifecycleHost(host);

    // ---- @Shortcut + @Timer: pending until attach --------------------------
    Editor ed = Editor();
    console.writeln("pre-attach=" + host.log.length().toString());   // 0
    ed.__sonarAttach();
    console.writeln("attach: " + host.dump());                       // bind ^S=1,timer 250=2

    // fire the shortcut + timer actions -> the methods run
    host.fireShortcut(0);
    host.fireShortcut(0);
    host.fireTimer(0);
    console.writeln("saves=" + ed.saves.toString() + " ticks=" + ed.ticks.toString());  // 2 / 1

    // detach unbinds the shortcut + cancels the timer
    host.reset();
    ed.__sonarDetach();
    console.writeln("detach: " + host.dump());                       // unbind 1,canceltimer 2

    // ---- @Validator via validateTree ---------------------------------------
    var vf1 = Sonar::validateTree(ed);
    console.writeln("ed invalid=" + vf1.length().toString() + " msg=" + (vf1.isEmpty() ? "-" : vf1[0].message));
    ed.name = "leviathan";
    var vf2 = Sonar::validateTree(ed);
    console.writeln("ed valid=" + vf2.length().toString());          // 0

    // ---- multiple attributes on one method ---------------------------------
    host.reset();
    Poller p = Poller();
    p.__sonarAttach();
    console.writeln("poller: " + host.dump());                       // bind ^P=..,timer 1000=..
    host.fireShortcut(host.shortcutActions.length() - 1);
    host.fireTimer(host.timerCbs.length() - 1);
    console.writeln("polls=" + p.polls.toString());                  // 2

    // ---- inherited-shortcut override dispatch ------------------------------
    host.reset();
    DerivedTool dt = DerivedTool();
    dt.__sonarAttach();
    console.writeln("derived bound: " + host.dump());                // bind ^B=..
    host.fireShortcut(host.shortcutActions.length() - 1);
    console.writeln("trace=" + dt.trace);                            // derived;

    // ---- validator ordering + message surfacing ----------------------------
    Form form = Form();
    var ff1 = Sonar::validateTree(form);
    console.writeln("form1=" + (ff1.isEmpty() ? "-" : ff1[0].message));   // A failed
    form.aOk = true;
    var ff2 = Sonar::validateTree(form);
    console.writeln("form2=" + (ff2.isEmpty() ? "-" : ff2[0].message));   // B failed
    form.bOk = true;
    var ff3 = Sonar::validateTree(form);
    console.writeln("form3=" + ff3.length().toString());                  // 0

    // ---- validateTree walks the whole subtree ------------------------------
    Sonar::Container root = Sonar::Container();
    Form child = Form();       // both validators fail
    root.add(child);
    var tree = Sonar::validateTree(root);
    console.writeln("tree failures=" + tree.length().toString());         // 1 (child's first)
}
