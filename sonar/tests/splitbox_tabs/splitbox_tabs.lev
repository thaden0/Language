uses Sonar;

class Counter { int hits = 0; void bump() { hits = hits + 1; } }
class LastInt { int value = 0; void set(int v) { value = v; } }

// Fills its own arranged box with a single glyph so paint-skip tests can
// tell (by reading Surface cells) whether a given child actually painted.
class Marker : Component {
    char glyph;
    new Marker(char g) { glyph = g; }
    void paintContent(Surface s) {
        if (box.isEmpty()) return;
        Style st;
        for (int y in box.y()..box.bottom() - 1)
            for (int x in box.x()..box.right() - 1)
                s.put(x, y, glyph, st);
    }
}

string readRow(Surface s, int y, int x0, int w) {
    string result = "";
    for (int x in x0..x0 + w - 1) {
        int scalar = s.cells().int32At(s.cellOffset(x, y));
        result = result + std::charFromCode(scalar).toString();
    }
    return result;
}

void main() {
    // =====================================================================
    // SplitBox
    // =====================================================================
    SplitBox sb = SplitBox();
    console.writeln(sb.axis == Axis::Horizontal);
    // bug.md #50: a single-quoted char literal fails to retype to `char` in
    // call-argument position; every glyph below is bound to a local first.
    char glyphL = 'L';
    char glyphR = 'R';
    Marker left = Marker(glyphL);
    Marker right = Marker(glyphR);
    sb.add(left);
    sb.add(right);

    sb.arrange(Rect(Point(0, 0), Size(21, 5)));
    console.writeln(left.box.x());
    console.writeln(left.box.w());
    console.writeln(right.box.x());
    console.writeln(right.box.w());

    sb.setRatio(80);
    sb.arrange(Rect(Point(0, 0), Size(21, 5)));
    console.writeln(left.box.w());
    console.writeln(right.box.w());

    // Min-clamp: a tiny ratio still leaves the first pane at minFirst (3).
    sb.setRatio(5);
    sb.arrange(Rect(Point(0, 0), Size(21, 5)));
    console.writeln(left.box.w());
    console.writeln(right.box.w());

    // Vertical axis split.
    SplitBox vsb = SplitBox();
    vsb.setAxis(Axis::Vertical);
    char glyphT = 'T';
    char glyphBo = 'B';
    Marker top = Marker(glyphT);
    Marker bottom = Marker(glyphBo);
    vsb.add(top);
    vsb.add(bottom);
    vsb.arrange(Rect(Point(0, 0), Size(10, 21)));
    console.writeln(top.box.h());
    console.writeln(bottom.box.y());
    console.writeln(bottom.box.h());

    // Third child throws (loud, per the language's loudness doctrine).
    char glyphX = 'X';
    Marker extra = Marker(glyphX);
    try { sb.add(extra); }
    catch (SonarException e) { console.writeln("split-add-3rd-throws"); }

    // setLayout throws (SplitBox is its own layout).
    try { sb.setLayout(FlexLayout(Axis::Horizontal)); }
    catch (SonarException e) { console.writeln("split-setLayout-throws"); }

    // Drag simulation: Press on the divider cell, Drag updates the ratio,
    // Release ends the drag. Divider sits at content-relative x = firstLen
    // (10, from the default 50% ratio over a 21-wide box:
    // (21-1)*50/100 = 10).
    SplitBox drag = SplitBox();
    char glyphA = 'A';
    char glyphB2 = 'B';
    Marker dl = Marker(glyphA);
    Marker dr = Marker(glyphB2);
    drag.add(dl);
    drag.add(dr);
    drag.arrange(Rect(Point(0, 0), Size(21, 5)));

    Counter resizeHits = Counter();
    LastInt lastRatio = LastInt();
    drag.onResize((pct) => { resizeHits.bump(); lastRatio.set(pct); });

    console.writeln(drag.hitsDivider(10, 2));
    drag.fireMouse(MouseEvent(MouseKind::Press, MouseButton::Left, 10, 2, 0));
    console.writeln(drag.dragging_);
    drag.fireMouse(MouseEvent(MouseKind::Drag, MouseButton::Left, 15, 2, 0));
    console.writeln(drag.ratioPct);
    console.writeln(resizeHits.hits);
    console.writeln(lastRatio.value);
    drag.fireMouse(MouseEvent(MouseKind::Release, MouseButton::Left, 15, 2, 0));
    console.writeln(drag.dragging_);

    // A Press off the divider does not start a drag.
    SplitBox missSb = SplitBox();
    char glyphM = 'm';
    char glyphN = 'n';
    Marker missLeft = Marker(glyphM);
    Marker missRight = Marker(glyphN);
    missSb.add(missLeft);
    missSb.add(missRight);
    missSb.arrange(Rect(Point(0, 0), Size(21, 5)));
    missSb.fireMouse(MouseEvent(MouseKind::Press, MouseButton::Left, 0, 0, 0));
    console.writeln(missSb.dragging_);

    // Divider paint: the box-drawing vertical bar at the divider column,
    // spaces elsewhere (Surface starts cleared).
    SplitBox paintSb = SplitBox();
    char glyphP = 'P';
    char glyphQ = 'Q';
    Marker pl = Marker(glyphP);
    Marker pr = Marker(glyphQ);
    paintSb.add(pl);
    paintSb.add(pr);
    paintSb.arrange(Rect(Point(0, 0), Size(21, 5)));
    Surface psurf = Surface(21, 5);
    Style plainStyle;
    psurf.clear(plainStyle);
    paintSb.paintChrome(psurf);
    console.writeln(readRow(psurf, 2, 0, 21));

    // Full paint() (real dispatch path, not a direct paintChrome() call):
    // both panes' children must actually render, not just the divider.
    // bug.md #65: relying on the INHERITED Container.paint() to walk
    // SplitBox's children silently painted nothing once SplitBox composed
    // a second mixin (Bordered/Styleable) alongside Container; SplitBox
    // now overrides paint() itself to work around it.
    Surface fullSurf = Surface(21, 5);
    Style fullPlain;
    fullSurf.clear(fullPlain);
    paintSb.paint(fullSurf);
    console.writeln(readRow(fullSurf, 2, 0, 21));

    // Border support: chrome()/contentRect() must actually inset for a set
    // border (bug.md #61/#65 — chrome() is now a leaf override for exactly
    // this reason). A bordered SplitBox's panes must not overlap the frame.
    SplitBox borderedSb = SplitBox();
    borderedSb.setBorder(BorderStyle::Single);
    console.writeln(borderedSb.chrome().top);
    borderedSb.box = Rect(Point(0, 0), Size(12, 6));
    console.writeln(borderedSb.contentRect().x());
    console.writeln(borderedSb.contentRect().y());
    console.writeln(borderedSb.contentRect().w());
    console.writeln(borderedSb.contentRect().h());
    Marker bl = Marker(glyphP);
    Marker br = Marker(glyphQ);
    borderedSb.add(bl);
    borderedSb.add(br);
    borderedSb.arrange(Rect(Point(0, 0), Size(12, 6)));
    console.writeln(bl.box.x());
    console.writeln(bl.box.y());
    console.writeln(br.box.right());
    console.writeln(br.box.bottom());
    Surface borderedSurf = Surface(12, 6);
    Style borderedPlain;
    borderedSurf.clear(borderedPlain);
    borderedSb.paint(borderedSurf);
    console.writeln(readRow(borderedSurf, 0, 0, 12));
    console.writeln(readRow(borderedSurf, 3, 0, 12));
    console.writeln(readRow(borderedSurf, 5, 0, 12));

    // =====================================================================
    // Tabs
    // =====================================================================
    Tabs tabs = Tabs();
    char glyph1 = '1';
    char glyph2 = '2';
    char glyph3 = '3';
    Marker t1 = Marker(glyph1);
    Marker t2 = Marker(glyph2);
    Marker t3 = Marker(glyph3);
    tabs.add("One", t1);
    tabs.add("Two", t2);
    tabs.add("Three", t3);
    console.writeln(tabs.labels_.joinToString(","));
    console.writeln(tabs.selected);

    Counter selCount = Counter();
    LastInt lastSel = LastInt();
    tabs.onSelect((idx) => { selCount.bump(); lastSel.set(idx); });

    tabs.select(1);
    console.writeln(tabs.selected);
    console.writeln(selCount.hits);
    console.writeln(lastSel.value);

    tabs.select(1);
    console.writeln(selCount.hits);

    tabs.select(99);
    console.writeln(tabs.selected);
    console.writeln(selCount.hits);

    // arrange: only the selected child gets a non-empty box; every other
    // child is still arranged (to an empty rect), not skipped. The strip
    // (three tabs, "Three" selected) overflows a 10-wide box, so arrange's
    // trailing ensureStripVisible() call should scroll to keep it visible.
    tabs.arrange(Rect(Point(0, 0), Size(10, 5)));
    console.writeln(tabs.tabStripScroll);
    console.writeln(t1.box.isEmpty());
    console.writeln(t2.box.isEmpty());
    console.writeln(t3.box.isEmpty());
    console.writeln(t3.box.w());
    console.writeln(t3.box.h());

    // paint: only the selected child's content shows.
    Surface tsurf = Surface(10, 5);
    Style tabsPlain;
    tsurf.clear(tabsPlain);
    tabs.paint(tsurf);
    console.writeln(readRow(tsurf, 2, 0, 10));
    console.writeln(readRow(tsurf, 0, 0, 10));

    // Left/Right/digit key navigation.
    tabs.fireKey(KeyEvent(KeyCode::Left, std::charFromCode(0), 0));
    console.writeln(tabs.selected);
    tabs.fireKey(KeyEvent(KeyCode::Right, std::charFromCode(0), 0));
    console.writeln(tabs.selected);
    char digitOne = '1';
    tabs.fireKey(KeyEvent(KeyCode::Char, digitOne, 0));
    console.writeln(tabs.selected);
    char digitThree = '3';
    tabs.fireKey(KeyEvent(KeyCode::Char, digitThree, 0));
    console.writeln(tabs.selected);
    char digitNine = '9';
    tabs.fireKey(KeyEvent(KeyCode::Char, digitNine, 0));
    console.writeln(tabs.selected);

    // Plain add(IComponent) auto-labels "Tab N".
    Tabs autoTabs = Tabs();
    char glyphAa = 'a';
    char glyphBb = 'b';
    autoTabs.add(Marker(glyphAa));
    autoTabs.add(Marker(glyphBb));
    console.writeln(autoTabs.labels_.joinToString(","));

    // remove drops the parallel label and re-clamps selection.
    Tabs removeTabs = Tabs();
    char glyphXx = 'x';
    char glyphYy = 'y';
    char glyphZz = 'z';
    Marker r1 = Marker(glyphXx);
    Marker r2 = Marker(glyphYy);
    Marker r3 = Marker(glyphZz);
    removeTabs.add("Alpha", r1);
    removeTabs.add("Beta", r2);
    removeTabs.add("Gamma", r3);
    removeTabs.remove(r2);
    console.writeln(removeTabs.labels_.joinToString(","));
    console.writeln(removeTabs.children().length());
    console.writeln(removeTabs.children()[0] == r1);
    console.writeln(removeTabs.children()[1] == r3);

    removeTabs.select(1);
    console.writeln(removeTabs.selected);
    removeTabs.remove(r3);
    console.writeln(removeTabs.selected);
    console.writeln(removeTabs.labels_.joinToString(","));

    // Strip overflow + scroll-to-keep-selected-visible.
    Tabs wideTabs = Tabs();
    char glyphW0 = '0';
    char glyphW1 = '1';
    char glyphW2 = '2';
    char glyphW3 = '3';
    char glyphW4 = '4';
    wideTabs.add("AAAAA", Marker(glyphW0));
    wideTabs.add("BBBBB", Marker(glyphW1));
    wideTabs.add("CCCCC", Marker(glyphW2));
    wideTabs.add("DDDDD", Marker(glyphW3));
    wideTabs.add("EEEEE", Marker(glyphW4));
    wideTabs.arrange(Rect(Point(0, 0), Size(20, 5)));
    console.writeln(wideTabs.tabStripScroll);
    wideTabs.select(4);
    console.writeln(wideTabs.tabStripScroll > 0);
    Surface wsurf = Surface(20, 5);
    Style widePlain;
    wsurf.clear(widePlain);
    wideTabs.paint(wsurf);
    console.writeln(readRow(wsurf, 0, 0, 20));
}
