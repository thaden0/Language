// Sonar Track 10 §3 — the scripted input source and the chord encoder.
//
// Owned by the test harness (not src/) to keep T03 pure: this is the REVERSE of
// keymap.lev's parseChord + input.lev's InputDecoder tables. Encoding a chord
// then decoding it back through InputDecoder must round-trip to the same
// KeyEvent — that round-trip is itself a test (§3, drift between encode/decode
// is a failure). Delivery model: ONE queued chunk per App.pumpOnce(), for
// deterministic interleaving of input and frames.
uses Sonar;

namespace SonarTest {
    // Encode a chord spec ("^S", "Tab", "Down", "C-x", "M-a", "S-Up") into the
    // raw terminal bytes InputDecoder decodes back into that KeyEvent. Mirrors
    // keymap.lev's parseChord grammar ([C-][M-][S-]key, ^X == C-X).
    string encodeChord(string spec) {
        string rem = spec;
        if (rem.startsWith("^") && rem.length() > 1)
            rem = "C-" + rem.subStr(1, rem.length() - 1);

        int mods = 0;
        bool scanning = true;
        while (scanning) {
            if (rem.startsWith("C-")) { mods = mods + Mod::Ctrl; rem = rem.subStr(2, rem.length() - 2); }
            else if (rem.startsWith("M-")) { mods = mods + Mod::Alt; rem = rem.subStr(2, rem.length() - 2); }
            else if (rem.startsWith("S-")) { mods = mods + Mod::Shift; rem = rem.subStr(2, rem.length() - 2); }
            else scanning = false;
        }
        if (rem.isEmpty()) throw SonarException("empty key in chord: " + spec);

        if (rem.length() == 1) {
            char key = rem.at(0);
            bool hasCtrl = (mods / Mod::Ctrl) % 2 == 1;
            bool hasAlt = (mods / Mod::Alt) % 2 == 1;
            string bytes;
            if (hasCtrl && key.isAlpha()) {
                char up = key.toUpper();
                bytes = std::charFromCode(up.code() - 64).toString();   // ^A..^Z == 1..26
            } else {
                bytes = key.toString();
            }
            if (hasAlt) bytes = esc() + bytes;                          // Alt = ESC prefix
            return bytes;
        }
        return encodeNamed(rem, mods);
    }

    string esc() => std::charFromCode(27).toString();
    string csi(string body) => esc() + "[" + body;
    string ss3(string body) => esc() + "O" + body;

    // Arrow/Home/End family: CSI <final>, or CSI 1;<mods+1> <final> when modified
    // (xterm modifier-param encoding; InputDecoder reads mods as param[1]-1).
    string csiFinal(string finalCh, int mods) {
        if (mods == 0) return csi(finalCh);
        return csi("1;" + (mods + 1).toString() + finalCh);
    }
    // PageUp/Delete/F5.. family: CSI <n>~, or CSI <n>;<mods+1>~ when modified.
    string csiTilde(int key, int mods) {
        if (mods == 0) return csi(key.toString() + "~");
        return csi(key.toString() + ";" + (mods + 1).toString() + "~");
    }

    // Named keys. Enter/Tab/Backspace ignore mods (the decoder has no modified
    // form for them, so an unmodified round-trip is all that is defined).
    string encodeNamed(string name, int mods) {
        if (name == "Enter") return std::charFromCode(13).toString();
        if (name == "Tab") return std::charFromCode(9).toString();
        if (name == "Backspace") return std::charFromCode(127).toString();
        if (name == "Escape") return esc();
        if (name == "BackTab") return csiFinal("Z", mods);
        if (name == "Up") return csiFinal("A", mods);
        if (name == "Down") return csiFinal("B", mods);
        if (name == "Right") return csiFinal("C", mods);
        if (name == "Left") return csiFinal("D", mods);
        if (name == "Home") return csiFinal("H", mods);
        if (name == "End") return csiFinal("F", mods);
        if (name == "Delete") return csiTilde(3, mods);
        if (name == "Insert") return csiTilde(2, mods);
        if (name == "PageUp") return csiTilde(5, mods);
        if (name == "PageDown") return csiTilde(6, mods);
        if (name == "F1") return ss3("P");
        if (name == "F2") return ss3("Q");
        if (name == "F3") return ss3("R");
        if (name == "F4") return ss3("S");
        if (name == "F5") return csiTilde(15, mods);
        if (name == "F6") return csiTilde(17, mods);
        if (name == "F7") return csiTilde(18, mods);
        if (name == "F8") return csiTilde(19, mods);
        if (name == "F9") return csiTilde(20, mods);
        if (name == "F10") return csiTilde(21, mods);
        if (name == "F11") return csiTilde(23, mods);
        if (name == "F12") return csiTilde(24, mods);
        throw SonarException("unknown key in chord: " + name);
    }
}

// The scripted IInputSource. Queues chunks and delivers ONE per drive step, so
// input and frames interleave deterministically under pumpOnce (§3).
class ScriptedInput : IInputSource {
    Array<string> queue_ = [];
    (string) => void sink_ = (b) => {};
    bool started_ = false;
    int stops_ = 0;

    // Queue raw bytes verbatim (escape sequences kept exactly).
    ScriptedInput feed(string bytes) { queue_ = queue_.add(bytes); return this; }
    // Convenience: a chord spec -> encoded bytes.
    ScriptedInput key(string chord) { return this.feed(SonarTest::encodeChord(chord)); }
    // A printable run.
    ScriptedInput text(string s) { return this.feed(s); }

    // Split the NEXT queued chunk at byte N into two chunks, so a sequence is
    // delivered across a chunk boundary (the decoder chunk-boundary fuzz hook,
    // T03's matrix). A no-op if the split index is out of range.
    ScriptedInput splitNext(int at) {
        if (queue_.isEmpty()) return this;
        string head = queue_[0];
        int n = head.length();
        if (at <= 0 || at >= n) return this;
        Array<string> rest = queue_.removeAt(0);
        Array<string> nq = [head.subStr(0, at), head.subStr(at, n - at)];
        for (string chunk in rest) nq = nq.add(chunk);
        queue_ = nq;
        return this;
    }

    // ---- IInputSource --------------------------------------------------
    void start((string) => void onBytes) { sink_ = onBytes; started_ = true; }
    void stop() { stops_ = stops_ + 1; started_ = false; }

    // ---- test-driven delivery (§3) -------------------------------------
    // Deliver one queued chunk to the decoder. Returns false when nothing is
    // queued or the session has not registered its sink yet.
    bool deliverNext() {
        if (!started_ || queue_.isEmpty()) return false;
        string chunk = queue_[0];
        queue_ = queue_.removeAt(0);
        var f = sink_;
        f(chunk);
        return true;
    }
    void drain() { while (this.deliverNext()) { } }
    int pending() => queue_.length();
    int stops() => stops_;
    bool started() => started_;
}
