// bug.md #58: a single-quoted char literal does not retype to `char` inside
// comptime-evaluated code (a macro body and the ordinary functions it calls),
// so `c == '<'` silently compares a char against a string and is always false.
// The identical code returns the right answer at runtime; `.code()` is correct
// in both. Distinct from #50 (which is about call-argument position at normal
// check time).
namespace M {
    bool startsLt(string s) { char c = s.chars()[0]; return c == '<'; }
    bool startsLtCode(string s) { char c = s.chars()[0]; return c.code() == 60; }
    macro litM(string p) comptime { if (M::startsLt(p)) return meta::parseExpr("1"); return meta::parseExpr("0"); }
    macro codeM(string p) comptime { if (M::startsLtCode(p)) return meta::parseExpr("1"); return meta::parseExpr("0"); }
}
void main() {
    console.writeln(M::startsLt("<x"));   // runtime: true   (char literal retypes)
    console.writeln(M::litM!(`<x`));      // comptime: 0  — WRONG, should be 1
    console.writeln(M::codeM!(`<x`));     // comptime: 1      (.code() is correct)
}
