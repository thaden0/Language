uses Sonar;

class Counter {
    int hits = 0;
    void bump() { hits = hits + 1; }
}
class LastString {
    string value = "";
    void set(string v) { value = v; }
}
class LastInt {
    int value = 0;
    void set(int v) { value = v; }
}
class LastBool {
    bool value = false;
    void set(bool v) { value = v; }
}

string readRow(Surface s, int y, int x0, int w) {
    string result = "";
    for (int x in x0..x0 + w - 1) {
        int scalar = s.cells().int32At(s.cellOffset(x, y));
        result = result + std::charFromCode(scalar).toString();
    }
    return result;
}

void main() {
    // ---- Text --------------------------------------------------------------
    Text t = Text();
    t.text("Hello World").align(Align::Center);
    console.writeln(t.text);
    console.writeln(t.align == Align::Center);

    Size unwrapped = t.contentDesired(Size(100, 10));
    console.writeln(unwrapped.w);
    console.writeln(unwrapped.h);

    Array<string> wrapped = wrapLines("the quick brown fox jumps", 10);
    console.writeln(wrapped.length());
    console.writeln(wrapped.joinToString("|"));

    Text multi = Text();
    multi.text("line1\nline2\nline3");
    Size msz = multi.contentDesired(Size(100, 10));
    console.writeln(msz.w);
    console.writeln(msz.h);

    Array<string> hardbreak = wrapLines("abcdefghij", 4);
    console.writeln(hardbreak.length());
    console.writeln(hardbreak.joinToString("|"));

    Text scrollCoerce = Text();
    scrollCoerce.wrap(Overflow::Scroll);
    console.writeln(scrollCoerce.wrap == Overflow::Clip);

    Text painted = Text();
    painted.text("Hi").align(Align::Center);
    painted.box = Rect(Point(0, 0), Size(6, 1));
    Surface textSurface = Surface(6, 1);
    Style plainStyle;
    textSurface.clear(plainStyle);
    painted.paintContent(textSurface);
    console.writeln(readRow(textSurface, 0, 0, 6));

    // ---- ContentBar ----------------------------------------------------------
    ContentBar bar = ContentBar();
    bar.setLeft("Left");
    bar.setCenter("Mid");
    bar.setRight("Right");
    Size barSize = bar.contentDesired(Size(100, 5));
    console.writeln(barSize.w);
    console.writeln(barSize.h);

    Surface wideBarSurface = Surface(20, 1);
    wideBarSurface.clear(plainStyle);
    bar.box = Rect(Point(0, 0), Size(20, 1));
    bar.paintContent(wideBarSurface);
    console.writeln(readRow(wideBarSurface, 0, 0, 20));

    Surface tightBarSurface = Surface(11, 1);
    tightBarSurface.clear(plainStyle);
    bar.box = Rect(Point(0, 0), Size(11, 1));
    bar.paintContent(tightBarSurface);
    console.writeln(readRow(tightBarSurface, 0, 0, 11));

    Surface tinyBarSurface = Surface(3, 1);
    tinyBarSurface.clear(plainStyle);
    bar.box = Rect(Point(0, 0), Size(3, 1));
    bar.paintContent(tinyBarSurface);
    console.writeln(readRow(tinyBarSurface, 0, 0, 3));

    // ---- Button ---------------------------------------------------------------
    Button btn = Button();
    btn.setLabel("OK");
    console.writeln(btn.displayText());
    btn.setKey("^S");
    console.writeln(btn.displayText());
    Size btnSize = btn.contentDesired(Size(50, 3));
    console.writeln(btnSize.w);
    console.writeln(btnSize.h);

    Counter pressCount = Counter();
    btn.onPress(() => pressCount.bump());
    btn.fireKey(KeyEvent(KeyCode::Enter, std::charFromCode(0), 0));
    console.writeln(pressCount.hits);
    char spaceCh = ' ';
    btn.fireKey(KeyEvent(KeyCode::Char, spaceCh, 0));
    console.writeln(pressCount.hits);
    console.writeln(btn.flashing_);
    btn.box = Rect(Point(0, 0), Size(20, 1));
    btn.paintContent(Surface(20, 1));
    console.writeln(btn.flashing_);

    btn.setEnabled(false);
    btn.fireKey(KeyEvent(KeyCode::Enter, std::charFromCode(0), 0));
    console.writeln(pressCount.hits);
    console.writeln(btn.isTabStop());

    // ---- CheckBox ---------------------------------------------------------------
    CheckBox cb = CheckBox();
    cb.setLabel("Accept");
    console.writeln(cb.checked);
    LastBool cbLast = LastBool();
    cb.onToggle((v) => cbLast.set(v));
    cb.fireKey(KeyEvent(KeyCode::Char, spaceCh, 0));
    console.writeln(cb.checked);
    console.writeln(cbLast.value);
    cb.fireKey(KeyEvent(KeyCode::Char, spaceCh, 0));
    console.writeln(cb.checked);
    console.writeln(cbLast.value);
    console.writeln(cb.validate());
    cb.addValidator(() => cb.checked, "must accept");
    cb.setChecked(false);
    console.writeln(cb.validate());
    console.writeln(cb.validationMessage());

    // ---- RadioGroup ---------------------------------------------------------------
    RadioGroup rg = RadioGroup();
    rg.setOptions(["A", "B", "C"]);
    console.writeln(rg.selected);
    LastInt rgLast = LastInt();
    rg.onSelect((idx) => rgLast.set(idx));
    rg.fireKey(KeyEvent(KeyCode::Down, std::charFromCode(0), 0));
    console.writeln(rg.selected);
    console.writeln(rgLast.value);
    rg.fireKey(KeyEvent(KeyCode::Down, std::charFromCode(0), 0));
    console.writeln(rg.selected);
    rg.fireKey(KeyEvent(KeyCode::Up, std::charFromCode(0), 0));
    console.writeln(rg.selected);

    rg.setOptions(["Only"]);
    console.writeln(rg.selected);

    RadioGroup fresh = RadioGroup();
    fresh.setOptions(["X", "Y"]);
    fresh.setRequireSelection(true);
    console.writeln(fresh.validate());
    console.writeln(fresh.validationMessage());
    fresh.selectRow(1);
    console.writeln(fresh.validate());
    LastInt freshLast = LastInt();
    freshLast.set(-99);
    fresh.onSelect((idx) => freshLast.set(idx));
    fresh.setOptions(["OnlyX"]);
    console.writeln(fresh.selected);
    console.writeln(freshLast.value);

    Size rgSize = rg.contentDesired(Size(50, 5));
    console.writeln(rgSize.w);
    console.writeln(rgSize.h);

    // ---- ProgressBar ---------------------------------------------------------------
    ProgressBar pb = ProgressBar();
    pb.setValue(50);
    pb.setMax(100);
    pb.box = Rect(Point(0, 0), Size(10, 1));
    Surface pbSurface = Surface(10, 1);
    pbSurface.clear(plainStyle);
    pb.paintContent(pbSurface);
    console.writeln(readRow(pbSurface, 0, 0, 10));

    pb.setShowPercent(true);
    Surface pbPctSurface = Surface(10, 1);
    pbPctSurface.clear(plainStyle);
    pb.paintContent(pbPctSurface);
    console.writeln(readRow(pbPctSurface, 0, 0, 10));

    pb.setValue(4);
    pb.setMax(100);
    pb.setShowPercent(false);
    Surface pbBoundarySurface = Surface(10, 1);
    pbBoundarySurface.clear(plainStyle);
    pb.paintContent(pbBoundarySurface);
    console.writeln(readRow(pbBoundarySurface, 0, 0, 10));

    Array<TimerReg> pbTimers = pb.__sonarPendingTimers();
    console.writeln(pbTimers.length());
    pb.indeterminate(true);
    var pbTick = pbTimers[0].action;
    pbTick();
    pbTick();
    Surface pbIndSurface = Surface(10, 1);
    pbIndSurface.clear(plainStyle);
    pb.paintContent(pbIndSurface);
    console.writeln(readRow(pbIndSurface, 0, 0, 10));

    // ---- Spinner ---------------------------------------------------------------
    Spinner sp = Spinner();
    Size spSize = sp.contentDesired(Size(10, 1));
    console.writeln(spSize.w);
    console.writeln(spSize.h);
    sp.box = Rect(Point(0, 0), Size(2, 1));
    Surface spSurface = Surface(2, 1);
    spSurface.clear(plainStyle);
    sp.paintContent(spSurface);
    console.writeln(readRow(spSurface, 0, 0, 2));

    Array<TimerReg> spTimers = sp.__sonarPendingTimers();
    console.writeln(spTimers.length());
    var spTick = spTimers[0].action;
    spTick();
    Surface spSurface2 = Surface(2, 1);
    spSurface2.clear(plainStyle);
    sp.paintContent(spSurface2);
    console.writeln(readRow(spSurface2, 0, 0, 2));

    // ---- Input ---------------------------------------------------------------
    Input inp = Input();
    inp.setPlaceholder("type here");
    console.writeln(inp.value);
    console.writeln(inp.cursor);

    LastString changeLast = LastString();
    Counter changeCount = Counter();
    inp.onChange((v) => { changeLast.set(v); changeCount.bump(); });
    Counter submitCount = Counter();
    inp.onSubmit((v) => submitCount.bump());

    inp.box = Rect(Point(0, 0), Size(6, 1));
    for (char c in "abc".chars()) inp.fireKey(KeyEvent(KeyCode::Char, c, 0));
    console.writeln(inp.value);
    console.writeln(inp.cursor);
    console.writeln(changeLast.value);
    console.writeln(changeCount.hits);

    inp.fireKey(KeyEvent(KeyCode::Left, std::charFromCode(0), 0));
    inp.fireKey(KeyEvent(KeyCode::Left, std::charFromCode(0), 0));
    console.writeln(inp.cursor);
    inp.fireKey(KeyEvent(KeyCode::Backspace, std::charFromCode(0), 0));
    console.writeln(inp.value);
    console.writeln(inp.cursor);
    inp.fireKey(KeyEvent(KeyCode::Delete, std::charFromCode(0), 0));
    console.writeln(inp.value);

    inp.fireKey(KeyEvent(KeyCode::End, std::charFromCode(0), 0));
    console.writeln(inp.cursor);
    inp.fireKey(KeyEvent(KeyCode::Home, std::charFromCode(0), 0));
    console.writeln(inp.cursor);

    inp.setValue("hello world foo");
    inp.fireKey(KeyEvent(KeyCode::End, std::charFromCode(0), 0));
    inp.fireKey(KeyEvent(KeyCode::Left, std::charFromCode(0), Mod::Ctrl));
    console.writeln(inp.cursor);
    inp.fireKey(KeyEvent(KeyCode::Left, std::charFromCode(0), Mod::Ctrl));
    console.writeln(inp.cursor);
    inp.fireKey(KeyEvent(KeyCode::Right, std::charFromCode(0), Mod::Ctrl));
    console.writeln(inp.cursor);

    inp.fireKey(KeyEvent(KeyCode::Enter, std::charFromCode(0), 0));
    console.writeln(submitCount.hits);

    Input capped = Input();
    capped.setMaxLength(3);
    for (char c in "abcdef".chars()) capped.fireKey(KeyEvent(KeyCode::Char, c, 0));
    console.writeln(capped.value);
    capped.firePaste(PasteEvent("xyz123"));
    console.writeln(capped.value);

    Input pasted = Input();
    pasted.box = Rect(Point(0, 0), Size(20, 1));
    pasted.firePaste(PasteEvent("pasted text"));
    console.writeln(pasted.value);
    console.writeln(pasted.cursor);

    Input masked = Input();
    char star = '*';
    masked.mask(star);
    masked.box = Rect(Point(0, 0), Size(10, 1));
    for (char c in "secret".chars()) masked.fireKey(KeyEvent(KeyCode::Char, c, 0));
    console.writeln(masked.value);
    console.writeln(masked.cellAt(masked.cursor));

    Input scrolled = Input();
    scrolled.box = Rect(Point(0, 0), Size(5, 1));
    for (char c in "0123456789".chars()) scrolled.fireKey(KeyEvent(KeyCode::Char, c, 0));
    console.writeln(scrolled.value);
    console.writeln(scrolled.cursor);
    console.writeln(scrolled.scrollCells);
    scrolled.fireKey(KeyEvent(KeyCode::Home, std::charFromCode(0), 0));
    console.writeln(scrolled.scrollCells);

    Input validated = Input();
    validated.validator((v) => v.length() >= 3);
    validated.setValidatorMessage("too short");
    console.writeln(validated.validate());
    validated.setValue("hi");
    console.writeln(validated.validate());
    console.writeln(validated.validationMessage());
    validated.setValue("hello");
    console.writeln(validated.validate());

    Input focusedInput = Input();
    focusedInput.setValue("abc");
    focusedInput.box = Rect(Point(2, 3), Size(10, 1));
    console.writeln(focusedInput.cursorPos() == None);
    focusedInput.setFocused(true);
    focusedInput.moveCursorTo(3);
    // cursorPos() is BOX-RELATIVE (App.renderFrame adds the box offset itself):
    // box origin is (2,3) but a cursor 3 cells in must report x=3, y=0 — NOT
    // the absolute (5,3), which would double-offset the caret on screen.
    Point? cpOpt = focusedInput.cursorPos();
    if (cpOpt != None) {
        Point cp = cpOpt;
        console.writeln(cp.x);
        console.writeln(cp.y);
    }
}
