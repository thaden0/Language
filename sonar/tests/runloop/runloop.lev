uses Sonar;

// A recording renderer (T10's RecordRenderer shape, C12): records grid + cursor +
// acquire/release, never emits escapes. Sized so screen()/layout are deterministic.
class RecordRenderer : IRenderer {
    int w; int h;
    Point? cursor = None;
    int presents = 0;
    int acquires = 0;
    int releases = 0;
    Surface last = Surface(1, 1);
    new RecordRenderer(int width, int height) { w = width; h = height; }
    Size size() => Size(w, h);
    void acquire(bool alt, bool mouse, bool paste) { acquires = acquires + 1; }
    void release() { releases = releases + 1; }
    void present(Surface s) { presents = presents + 1; last = s; }
    void setCursor(Point? p) { cursor = p; }
    void bell() { }
}

// Scripted input source (C12): captures the onBytes sink; push() feeds bytes
// through the real decoder synchronously.
class ScriptedInput : IInputSource {
    (string) => void sink;
    bool has = false;
    int stops = 0;
    void start((string) => void onBytes) { sink = onBytes; has = true; }
    void stop() { stops = stops + 1; }
    void push(string bytes) { if (has) { var f = sink; f(bytes); } }
}

// Non-drawing focusable leaf (empty paintContent): exercises focus/keymap/input
// without touching the Surface fill/put path (bug.md #57).
class Field : Focusable {
    string name;
    int keys = 0;
    new Field(string n) {
        name = n;
        this.onKey((e) => this.bump());
    }
    void bump() { keys = keys + 1; }
    Size contentDesired(Size avail) => Size(4, 1);
    Point? cursorPos() => Point(1, 0);
}

class Counter { int hits = 0; void bump() { hits = hits + 1; } }

string fieldName(Focusable? f) {
    if (f != None) {
        Focusable leaf = f;
        if (leaf is Field) { Field fd = leaf; return fd.name; }
        return "?";
    }
    return "none";
}
string pointStr(Point? p) {
    if (p != None) {
        Point pt = p;
        return pt.x.toString() + "," + pt.y.toString();
    }
    return "none";
}
string vis(string s) {
    StringBuilder o = StringBuilder();
    for (char c in s.chars()) {
        int b = c.code();
        if (b == 27) o.add("^");
        else if (b < 32) o.add("?");
        else o.add(c.toString());
    }
    return o.toString();
}

void main() {
    console.writeln("== version/nowMs ==");
    console.writeln(Sonar::version());
    console.writeln(nowMs() > 0);

    console.writeln("== single-app rule ==");
    App a = App();
    RecordRenderer tr = RecordRenderer(20, 4);
    ScriptedInput si = ScriptedInput();
    a.__useRenderer(tr);
    a.__useInput(si);
    a.__useSignalResize(false);
    try { App b = App(); } catch (SonarException e) { console.writeln("second-app-throws"); }

    console.writeln("== app() accessor ==");
    console.writeln(app() == a);

    Field f1 = Field("one");
    Field f2 = Field("two");
    a.add(f1);
    a.add(f2);

    console.writeln("== pumpOnce present + acquire ==");
    a.pumpOnce();
    console.writeln("presents=" + tr.presents.toString());
    console.writeln("acquires=" + tr.acquires.toString());
    console.writeln("screen=" + a.screen().w.toString() + "x" + a.screen().h.toString());

    console.writeln("== config after run throws ==");
    try { a.title("x"); } catch (SonarException e) { console.writeln("reconfig-throws"); }

    console.writeln("== focus + tab traversal ==");
    a.focus(f1);
    console.writeln("focused=" + fieldName(a.focused()));
    si.push("\t");
    console.writeln("afterTab=" + fieldName(a.focused()));
    si.push("\t");
    console.writeln("afterTab2=" + fieldName(a.focused()));

    console.writeln("== key to focused ==");
    a.focus(f1);
    si.push("x");
    console.writeln("f1keys=" + f1.keys.toString());

    console.writeln("== keymap chord ==");
    Counter c = Counter();
    a.keymap().bind("^S", () => c.bump());
    si.push("\x13");
    console.writeln("chord=" + c.hits.toString());

    console.writeln("== every/cancelEvery ==");
    int tok = a.every(50, () => c.bump());
    a.cancelEvery(tok);
    console.writeln("timer-registered-and-cancelled");

    console.writeln("== overlays ==");
    Field ov = Field("overlay");
    a.pushOverlay(ov);
    console.writeln("hasOverlay=" + (a.topOverlay() != None).toString());
    a.popOverlay();
    console.writeln("hasOverlay=" + (a.topOverlay() != None).toString());

    console.writeln("== cursor after frame (focused f1) ==");
    a.focus(f1);
    a.pumpOnce();
    console.writeln("cursor=" + pointStr(tr.cursor));

    console.writeln("== quit + teardown ==");
    a.quit();
    a.stopSession();
    console.writeln("input-stops=" + si.stops.toString());
    __sonarResetApp();

    console.writeln("== AnsiRenderer diff (direct surface) ==");
    Surface s = Surface(6, 2);
    Style plain; s.clear(plain);
    s.writeText(0, 0, "hi", Style(Color::Red, Color::Default, Attr::Bold));
    AnsiRenderer r = AnsiRenderer();
    r.__capture(true);
    r.present(s);
    console.writeln(vis(r.__drainCapture()));
    console.writeln("changed=" + cellsChanged().toString());
    r.present(s);
    console.writeln("nochange=[" + vis(r.__drainCapture()) + "]");
    s.writeText(3, 1, "X", Style(Color::Green, Color::Default, 0));
    r.present(s);
    console.writeln(vis(r.__drainCapture()));
    console.writeln("changed2=" + cellsChanged().toString());
    r.bell();
    console.writeln("bell=" + vis(r.__drainCapture()));
}
