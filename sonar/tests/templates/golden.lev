uses Sonar;

// M0 runtime golden harness (design §5/§7): the template engine is exercised
// as a pure string->string library — the exact code path the `sonar!` macro
// runs at comptime — so every grammar production and every error is pinned
// here without needing F4. Each case prints its expansion (or caught error
// message); the .expected file locks the bytes.

// A `${...}` interpolation hole. Built by concatenation because Leviathan's
// own lexer interpolates a literal `${` inside a "double-quoted" string — real
// `sonar!` callers use raw backtick payloads (or import()ed .sonar files),
// which are exempt; this harness feeds ordinary strings, so it splices `${`.
string h(string expr) { return "$" + "{" + expr + "}"; }

void show(string title, string payload) {
    console.writeln("### " + title);
    console.writeln(Sonar::expandSonar(payload));
    console.writeln("");
}

void showErr(string title, string payload) {
    console.writeln("### " + title);
    try {
        console.writeln(Sonar::expandSonar(payload));
        console.writeln("!! expected an error, got none");
    } catch (SonarException e) {
        console.writeln(e.message);
    }
    console.writeln("");
}

void main() {
    // ---- grammar productions ----
    show("self-closing", "<Text/>");
    show("open-close empty", "<Container></Container>");
    show("nested children", "<Container><Text text=\"Hi\"/><Text text=\"Bye\"/></Container>");
    show("qualified tag", "<Views::Panel/>");

    // ---- attribute forms (design §3.2) ----
    show("literal string attr", "<Text text=\"Hello\"/>");
    show("expr attr", "<Text text={user.name}/>");
    show("enum literal attr", "<Text align=\"Center\" wrap=\"Wrap\"/>");
    show("int + bool literal", "<ProgressBar value=\"40\" showPercent=\"true\"/>");
    show("char literal (mask)", "<Input mask=\"*\"/>");

    // ---- layout sugar (design §3.2) ----
    show("width fixed", "<Text width=\"30\"/>");
    show("width expr", "<Text width={custom}/>");
    show("flex both axes", "<Text flex=\"1\"/>");
    show("flex overridden by width", "<Text flex=\"2\" width=\"30\"/>");
    show("min/max bounded merge", "<Text minWidth=\"5\" maxWidth=\"40\"/>");
    show("min + flex bounded", "<Text minHeight=\"3\" flex=\"2\"/>");
    show("dock enum", "<Text dock=\"Top\"/>");
    show("grid cells", "<Text row=\"1\" col=\"2\" rowSpan=\"1\" colSpan=\"3\"/>");
    show("padding uniform", "<Text padding=\"2\"/>");
    show("hidden", "<Text hidden={collapsed}/>");

    // ---- id + on: handlers (design §3.1/§3.2) ----
    show("id binding", "<Input id=\"nameField\"/>");
    show("on: event handler", "<Button on:press={this.save}/>");
    show("on:key common + lambda", "<Text on:key={(e) => this.onKey(e)}/>");
    show("hole with nested braces", "<Text on:key={(e) => { this.onKey(e); }}/>");

    // ---- text, holes, whitespace (design §3.3) ----
    show("plain text child", "<Text>Hello world</Text>");
    show("text with hole", "<Text>Hello " + h("name") + "!</Text>");
    show("multiline whitespace collapse", "<Container>\n    one\n    two\n</Container>");
    show("explicit space idiom", "<Text>Hello" + h("\" \"") + h("name") + "</Text>");
    show("escapes in text", "<Text>a \\< b \\{ c \\$ d</Text>");

    // ---- control flow (design §3.3) ----
    show("for loop", "<Container>$for item in items { <Text text={item}/> }</Container>");
    show("if only", "<Container>$if ready { <Text text=\"go\"/> }</Container>");
    show("if/else", "<Container>$if ok { <Text text=\"y\"/> } $else { <Text text=\"n\"/> }</Container>");

    // ---- tabLabel routing (design §3.2) ----
    show("tabLabel routes to parent add", "<Tabs><Text tabLabel=\"One\" text=\"a\"/></Tabs>");

    // ---- unknown-tag pass-through (design §3.2/E3) ----
    show("unknown tag pass-through", "<MyPanel title=\"Custom\" count={n}/>");
    show("unknown tag common attrs still work", "<MyPanel width=\"20\" id=\"panel\"/>");

    // ---- the design's own §3.1 example (T05 tags pass through) ----
    show("design 3.1 example",
        "<ContentBox title=\"Files\" border={BorderStyle::Single}><ListView id=\"files\" flex=\"1\"/></ContentBox>");

    // ---- error catalog E1-E9 (design §4) ----
    showErr("E1 unclosed tag (EOF)", "<Container><Text/>");
    showErr("E1 mismatched close", "<Container><Text/></Box>");
    showErr("E2 malformed attr (no =)", "<Text title/>");
    showErr("E2 unquoted value", "<Text text=Hello/>");
    showErr("E3 unknown attr with suggestion", "<Text tex=\"x\"/>");
    showErr("E3 unknown attr no suggestion", "<Text zzz=\"x\"/>");
    showErr("E4 id inside for", "<Container>$for x in xs { <Text id=\"a\"/> }</Container>");
    showErr("E5 unbalanced brace", "<Text width={1 + 2/>");
    showErr("E6 for missing var", "<Container>$for in xs { <Text/> }</Container>");
    showErr("E8 empty payload", "");
    showErr("E8 text root", "just text");
    showErr("E9 theme deferred", "<Text theme=\"key\"/>");
}
