// Regression: Sonar bug #4 — a leaf's in-place repaint to SHORTER content
// must clear its whole box, leaving no stale glyphs from the previous, longer
// content. A damage-driven repaint of a lone dirty leaf runs only
// paintBackground+paintContent within the leaf's own box (the App root's
// full-surface clear does NOT run, because the App itself is not dirty). Before
// the fix, under the default/empty theme Styleable.paintBackground skipped its
// fill, so the tail of the old content survived under the new one. Now
// paintBackground fills unconditionally.
uses Sonar;

// Render a row mapping blank (NUL) and space cells to '.', like the
// TestRenderer's channel-1 dump — avoids trailing-whitespace golden fragility.
string vis(Surface s, int y, int w) {
    StringBuilder o = StringBuilder();
    for (int x in 0..w - 1) {
        int sc = s.cells().int32At(s.cellOffset(x, y));
        if (sc == 0 || sc == 32) o.add(".");
        else o.add(std::charFromCode(sc).toString());
    }
    return o.toString();
}

void main() {
    Surface surf = Surface(20, 1);
    Style plain;
    surf.clear(plain);                       // App root's first full-surface clear

    ContentBar bar = ContentBar();
    bar.box = Rect(Point(0, 0), Size(20, 1));

    // First paint: long content.
    bar.setLeft("READMExx");
    bar.paint(surf);
    console.writeln(vis(surf, 0, 20));

    // Damage-driven leaf repaint to SHORTER content: only the leaf's box is
    // re-clipped and repainted. The tail ("ADMExx") must be cleared.
    bar.setLeft("hi");
    surf.pushClip(bar.box);
    bar.paint(surf);
    surf.popClip();
    console.writeln(vis(surf, 0, 20));
}
