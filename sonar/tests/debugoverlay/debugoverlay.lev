uses Sonar;

string readRow(Surface s, int y, int x0, int w) {
    string r = "";
    for (int x in x0..x0 + w - 1)
        r = r + std::charFromCode(s.cells().int32At(s.cellOffset(x, y))).toString();
    return r.trimEnd();
}

void main() {
    Sonar::App app = Sonar::App();

    // seed the diagnostics ring + a frame-stats sample
    Sonar::log("started");
    Sonar::log("tick 1");
    Sonar::log("tick 2");
    Sonar::recordFrameStats(FrameStats(3, 5, 12, 42));

    // ---- direct paint: stats line then the last log entries ----------------
    DebugOverlay ov = DebugOverlay();
    ov.lines(4);
    ov.box = Rect(Point(0, 0), Size(40, 5));
    Surface surf = Surface(40, 6);
    Style plain;
    surf.clear(plain);
    ov.paint(surf);
    console.writeln("[" + readRow(surf, 0, 0, 40) + "]");
    console.writeln("[" + readRow(surf, 1, 0, 40) + "]");
    console.writeln("[" + readRow(surf, 2, 0, 40) + "]");
    console.writeln("[" + readRow(surf, 3, 0, 40) + "]");

    // ---- App.debugOverlay(true): pushed but INPUT-TRANSPARENT --------------
    console.writeln("before: overlays=" + app.overlayCount().toString() +
        " on=" + app.debugOverlayOn().toString());
    app.debugOverlay(true);
    // it is on the stack (paints) but does not own input (dispatch skips it)
    console.writeln("on: overlays=" + app.overlayCount().toString() +
        " on=" + app.debugOverlayOn().toString() +
        " topInputNone=" + (app.topInputOverlay() == None).toString() +
        " topOverlayPresent=" + (app.topOverlay() != None).toString());

    // idempotent
    app.debugOverlay(true);
    console.writeln("re-on: overlays=" + app.overlayCount().toString());

    app.debugOverlay(false);
    console.writeln("off: overlays=" + app.overlayCount().toString() +
        " on=" + app.debugOverlayOn().toString());

    Sonar::__sonarResetApp();
}
