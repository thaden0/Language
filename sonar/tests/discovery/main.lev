// M3: the SAME test classes as tests/registry_runner/main.lev, but discovered
// automatically via @Test — no seedAll(), no __seed/__entry by hand. The
// report must be BYTE-IDENTICAL to the hand-seeded twin (the rule_orm twin
// discipline applied to Sonar itself).
uses sonar;

class MathTests {
    @Test void addsNumbers() { sonar::assertEqual(4, 2 + 2); }
    @Test void subtractsNumbers() { sonar::assertEqual(0, 2 - 2); }
}

class StringTests {
    @Test void concatenates() { sonar::assertEqual("ab", "a" + "b"); }
    @Test void rejectsEmptyName() { sonar::assertEqual("", "bob"); }   // FAILs
    @Test void explodes() { throw RuntimeException("boom"); }             // ERRORs
    @Test @Skip void flaky() { }                                         // skipped
}

class LifecycleTests : IDisposable {
    void close() { console.writeln("      (LifecycleTests torn down)"); }
    @Test void passes() { sonar::assertTrue(true); }
    @Test void fails() { sonar::assertTrue(false, "deliberate lifecycle failure"); }
}

// A @Test on a non-void method: the runner reports it as an ERROR (misdeclared),
// never silently drops it (§5.4). Discovery's third $for catches it — proving
// discovery generates the same "badSignature" entry the twin hand-seeds.
class BadTests {
    @Test int badSignature() => 1;
}

sonar::main();
