uses Sonar;

// Exercises the REAL blocking run() loop (M1) + unconditional teardown (M6):
// a timer quits shortly after the loop starts; run() must return, its `using
// TerminalSession` must have acquired then released, and stopSession must have
// stopped the input source and cancelled timers so the process exits.
class RecordRenderer : IRenderer {
    int w; int h;
    int acquires = 0;
    int releases = 0;
    new RecordRenderer(int width, int height) { w = width; h = height; }
    Size size() => Size(w, h);
    void acquire(bool alt, bool mouse, bool paste) { acquires = acquires + 1; }
    void release() { releases = releases + 1; }
    void present(Surface s) { }
    void setCursor(Point? p) { }
    void bell() { }
}
class ScriptedInput : IInputSource {
    (string) => void sink;
    bool has = false;
    int stops = 0;
    void start((string) => void onBytes) { sink = onBytes; has = true; }
    void stop() { stops = stops + 1; }
}

void main() {
    App a = App();
    RecordRenderer tr = RecordRenderer(10, 3);
    ScriptedInput si = ScriptedInput();
    a.__useRenderer(tr).__useInput(si).__useSignalResize(false).altScreen(true).mouse(true);

    // Quit from a timer once the loop is pumping.
    a.every(5, () => a.quit());

    console.writeln("before-run");
    a.run();
    console.writeln("after-run");
    console.writeln("acquires=" + tr.acquires.toString());
    console.writeln("releases=" + tr.releases.toString());
    console.writeln("input-stops=" + si.stops.toString());
    __sonarResetApp();
}
