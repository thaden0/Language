uses Sonar;
uses Sonar::Dom;

// Build a small annotated tree by hand (D02's markup builder is a separate
// track; here we drive Document.__recordBuild directly, as the builder will).
Button makeButton(Document doc, App app, string id, string label, string cls, string action) {
    Button b = Button();
    b.setLabel(label);
    app.add(b);
    doc.__recordBuild(b, "button", ["id", "class", "action"], [id, cls, action]);
    return b;
}

void section(string name) { console.writeln("== " + name + " =="); }

// Closures capture primitive locals by value here; a ref class makes the
// mutation observable (D00 §7 house rule: anything a closure mutates is a class).
class Ctr { int n = 0; }

void reportCompileError(string sel) {
    try {
        compileSelector(sel);
        console.writeln("NO THROW: " + sel);
    } catch (SonarException e) {
        console.writeln(e.message);
    }
}

void main() {
    SonarApp app = SonarApp();
    Document doc = app.document();

    // --- tree: a menu Container holding two buttons + a checkbox + input -----
    Container menu = Container();
    app.add(menu);
    doc.__recordBuild(menu, "menu", ["id", "class"], ["main-menu", "bar"]);

    Button open = Button(); open.setLabel("Open");
    menu.add(open);
    doc.__recordBuild(open, "button", ["id", "class", "action"], ["file-open", "primary", "open"]);

    Button save = Button(); save.setLabel("Save");
    menu.add(save);
    doc.__recordBuild(save, "button", ["id", "class"], ["file-save", "primary"]);

    CheckBox agree = CheckBox();
    menu.add(agree);
    doc.__recordBuild(agree, "checkbox", ["id"], ["agree"]);

    Input name = Input(); name.setValue("alice");
    app.add(name);
    doc.__recordBuild(name, "input", ["id", "placeholder"], ["name", "your name"]);

    // ---- selectors --------------------------------------------------------
    section("selectors");
    console.writeln(app.queryAll("button").length());        // 2
    console.writeln(app.queryAll(".primary").length());      // 2
    console.writeln(app.queryAll("menu > button").length()); // 2 (direct children)
    console.writeln(app.queryAll("menu button").length());   // 2 (descendant)
    console.writeln(app.queryAll("app button").length());    // 0 (no 'app' tag meta)
    console.writeln(app.queryAll("#file-open, #file-save").length()); // 2
    console.writeln(app.queryAll("[action]").length());      // 1 (only open has action)
    console.writeln(app.queryAll("button[action=open]").length()); // 1
    console.writeln(app.query("#file-open").text());         // Open

    // ---- DomNode accessors ------------------------------------------------
    section("domnode");
    DomNode nOpen = app.query("#file-open");
    console.writeln(nOpen.id());                 // file-open
    console.writeln(nOpen.text());               // Open
    nOpen.text("Open File");
    console.writeln(nOpen.text());               // Open File
    console.writeln(nOpen.hasClass("primary"));  // true
    nOpen.addClass("wide").addClass("wide");     // idempotent
    console.writeln(nOpen.hasClass("wide"));     // true
    nOpen.removeClass("primary");
    console.writeln(nOpen.hasClass("primary"));  // false
    console.writeln(nOpen.attr("action"));       // open
    nOpen.attr("action", "open-file");
    console.writeln(nOpen.attr("action"));       // open-file

    DomNode nAgree = app.query("#agree");
    console.writeln(nAgree.checked());           // false
    nAgree.checked(true);
    console.writeln(nAgree.checked());           // true
    console.writeln(nAgree.value());             // true (checkbox value channel)

    DomNode nName = app.query("#name");
    console.writeln(nName.value());              // alice
    nName.value("bob");
    console.writeln(nName.value());              // bob
    console.writeln(nName.enabled());            // true
    nName.enabled(false);
    console.writeln(nName.enabled());            // false

    // visibility via hidden class
    console.writeln(nName.visible());            // true
    nName.hide();
    console.writeln(nName.visible());            // false
    console.writeln(nName.hasClass("hidden"));   // true
    nName.show();
    console.writeln(nName.visible());            // true

    // position (D-C5; D03 replaces the interim seam with live-read/stored-write
    // views). nOpen is not laid out here, so the live `.x` read is 0; the stored
    // desire surfaces through __resolveAbsolute (what an Absolute container uses).
    Position pos = nOpen.position();
    pos.method = PositionMethod::Absolute;
    pos.x = 7;
    pos.y = 3;
    console.writeln(pos.__resolveAbsolute(Size(0, 0)).x());   // 7
    console.writeln(pos.method == PositionMethod::Absolute);  // true

    // actions (D-C7 interim seam)
    Ctr fired = Ctr();
    nOpen.actions().add("open", () => { fired.n = fired.n + 1; });
    console.writeln(nOpen.actions().fire("open"));  // true
    console.writeln(fired.n);                        // 1

    // events (uniform hook) — just verify binding doesn't disturb the node
    Ctr keys = Ctr();
    nName.on("key", () => { keys.n = keys.n + 1; });
    console.writeln(app.queryOrNone("#name") == None ? "gone" : "present");   // present

    // tree ops
    console.writeln(nOpen.parent() == None ? "root" : "child");  // child
    console.writeln(app.query("#main-menu").children().length()); // 3

    // ---- DomNodeList broadcasts -------------------------------------------
    section("nodelist");
    DomNodeList primaries = app.queryAll(".primary");   // only save now (open lost .primary)
    console.writeln(primaries.length());                // 1
    app.queryAll("button").addClass("btn");
    console.writeln(app.queryAll(".btn").length());     // 2
    app.queryAll(".btn").hide();
    console.writeln(nOpen.visible());                   // false
    app.queryAll(".btn").show();
    console.writeln(nOpen.visible());                   // true

    // ---- id index: duplicate + revalidation after detach ------------------
    section("id-index");
    try {
        Button dup = Button();
        app.add(dup);
        doc.registerId("file-save", dup);   // live duplicate -> throws
        console.writeln("NO THROW");
    } catch (SonarException e) {
        console.writeln(e.message);         // duplicate id 'file-save'
    }

    // detach the menu subtree; the id index is stale until validated
    menu.setParent(None);
    console.writeln(app.queryOrNone("#file-open") == None ? "gone" : "present");  // gone
    console.writeln(doc.byId("file-open") == None ? "none" : "some");             // none

    // reap flatness: capacity before/after churn (free-list reuse)
    int capBefore = doc.__slotCapacity();
    int reaped = doc.__reap();
    console.writeln(reaped > 0);                          // true (menu subtree reaped)
    Container menu2 = Container();
    app.add(menu2);
    doc.__recordBuild(menu2, "menu", ["id"], ["menu2"]);
    Button b2 = makeButton(doc, app, "b2", "B2", "primary", "b2");
    menu2.add(b2);
    int capAfter = doc.__slotCapacity();
    console.writeln(capAfter <= capBefore);              // true (recycled, no growth)

    // ---- serializer -------------------------------------------------------
    // `save`/`open` were under the detached+reaped `menu`, so they serialize as
    // unmapped placeholders now (reaped -> no meta). Serialize attached nodes.
    section("serializer");
    console.writeln(doc.outerMarkup(save));                  // <!-- unmapped --> (reaped)
    console.writeln(app.query("#name").outerMarkup());       // input, still attached
    console.writeln(app.query("#menu2").outerMarkup());      // menu2 + b2

    // ---- selector compile errors ------------------------------------------
    section("errors");
    reportCompileError("a >> b");
    reportCompileError("#");
    reportCompileError("[unterminated");
    reportCompileError("> x");
}
