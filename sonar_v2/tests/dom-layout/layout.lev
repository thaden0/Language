uses Sonar;
uses Sonar::Dom;

// D03 differential test (techdesign-03): Position (live reads / stored writes /
// anchors / w-h overrides), FlexContainer + Bar absolute-aware arrange, the z
// paint order, semantic classes + class-qualified theming resolve, and the
// popover route. Scalar assertions only (coordinates/booleans/strings), driven
// by direct arrange() calls — no renderer needed, fully deterministic across the
// oracle/IR/LLVM engines.

void section(string s) { console.writeln("== " + s + " =="); }
void xy(string label, Rect r) {
    console.writeln(label + " " + r.x().toString() + "," + r.y().toString());
}

void main() {
    SonarApp app = SonarApp();
    Document doc = app.document();

    // ---- Position + absolute arrange in a FlexContainer -------------------
    section("position/absolute");
    FlexContainer main = FlexContainer(Axis::Vertical);
    app.add(main);

    Text a = Text(); a.text("AAA"); main.add(a);          // flow
    Text f = Text(); f.text("float"); main.add(f);        // absolute
    Text b = Text(); b.text("BBB"); main.add(b);          // flow
    Text g = Text(); g.text("gg"); main.add(g);           // absolute + w/h
    Text tip = Text(); tip.text("tip"); main.add(tip);    // absolute + anchor

    Position fp = f.position();
    fp.method = PositionMethod::Absolute;
    fp.x = 10; fp.y = 4;
    // Live read BEFORE arrange: the box is not laid out yet, so the LIVE `x`
    // reports the box origin (0), NOT the stored desire (10) — the read/write
    // asymmetry (D-C5).
    console.writeln(fp.x);                    // 0

    Position gp = g.position();
    gp.method = PositionMethod::Absolute;
    gp.x = 2; gp.y = 2; gp.w = 5; gp.h = 3;   // w/h -> Constraint::Fixed on owner

    Position tp = tip.position();
    tp.method = PositionMethod::Absolute;
    tp.anchorTo(a, AnchorEdge::Below);        // resize-proof anchor

    main.measure(Size(40, 10));               // measure then arrange (frame order)
    main.arrange(Rect(Point(0, 0), Size(40, 10)));

    console.writeln(a.box.y());               // 0  (flow)
    console.writeln(b.box.y());               // 1  (flow; abs f took no flow space)
    console.writeln(fp.x);                    // 10 (live read now reflects placement)
    console.writeln(fp.y);                    // 4
    console.writeln(g.box.w());               // 5  (Fixed override honored)
    console.writeln(g.box.h());               // 3
    console.writeln(tip.box.x());             // 0  (anchor a.x)
    console.writeln(tip.box.y());             // 1  (anchor a.bottom())

    // ---- Bar: horizontal, one-row default --------------------------------
    section("bar");
    Bar bar = Bar();
    app.add(bar);
    Text l = Text(); l.text("L"); bar.add(l);
    Text r = Text(); r.text("R"); bar.add(r);
    bar.measure(Size(40, 1));
    bar.arrange(Rect(Point(0, 20), Size(40, 1)));
    console.writeln(l.box.x());                    // 0
    console.writeln(r.box.x());                    // 1 (horizontal)
    console.writeln(bar.heightConstraint().concrete);  // 1 (Fixed(1) default)

    // ---- markup constructor (delegates to D02) ---------------------------
    section("markup ctor");
    FlexContainer built = FlexContainer(
        "<button id=\"go\">Go</button><button id=\"stop\">Stop</button>");
    app.add(built);
    console.writeln(built.queryAll("button").length());  // 2
    console.writeln(built.query("#go").text());          // Go

    // ---- classes: semantic hidden + class-qualified theming --------------
    section("classes");
    Text err = Text(); err.text("oops"); app.add(err);
    err.addClass("error");
    console.writeln(err.hasClass("error"));   // true
    err.addClass("hidden");
    console.writeln(err.visible());           // false (hidden couples visibility)
    err.removeClass("hidden");
    console.writeln(err.visible());           // true

    console.writeln(classBaseKey("input.focused.text", "error"));  // input.error
    console.writeln(classFullKey("input.focused.text", "error"));  // input.error.focused.text

    Theme th = Theme();
    th.set("text", Style(Color::White, Color::Default, 0));
    th.set("text.error", Style(Color::Red, Color::Default, 0));
    installTheme(th);
    Style es = resolveOrDefault(err, "text");
    console.writeln(es.fg == Color::Red);     // true  (class layer wins)
    Text plain = Text(); plain.text("ok"); app.add(plain);
    Style ps = resolveOrDefault(plain, "text");
    console.writeln(ps.fg == Color::White);   // true  (no class -> component base)

    // ---- z paint order (stable by z ascending) ---------------------------
    section("z-order");
    FlexContainer zc = FlexContainer();
    Text z1 = Text(); z1.text("z1"); zc.add(z1);
    Text z2 = Text(); z2.text("z2"); zc.add(z2);
    Text z3 = Text(); z3.text("z3"); zc.add(z3);
    z1.position().method = PositionMethod::Absolute; z1.position().z = 5;
    z2.position().method = PositionMethod::Absolute; z2.position().z = 1;
    z3.position().method = PositionMethod::Absolute; z3.position().z = 1;
    Array<IComponent> ordered = absByZOf(zc.children());
    string acc = "";
    for (IComponent c in ordered) if (c is Text) { Text t = c; acc = acc + t.text + " "; }
    console.writeln(acc);                     // z2 z3 z1  (stable at equal z)

    // ---- anchor edges + resize tracking (the resize-proof value prop) -----
    // §9 "anchor edges × resize scripts". A known-box absolute target (10,5,4,2
    // => right 14, bottom 7) with one Fixed-3x1 float per edge exercises every
    // anchorX/anchorY branch; moving the target then re-arranging proves the
    // floats track it (the enhancement over the sketch's manual `.y = t.y + 1`);
    // clearAnchor drops back to the stored desired coords.
    section("anchors");
    FlexContainer ac = FlexContainer();
    Text tgt = Text(); tgt.text("T"); ac.add(tgt);
    Position tgp = tgt.position();
    tgp.method = PositionMethod::Absolute;
    tgp.x = 10; tgp.y = 5; tgp.w = 4; tgp.h = 2;
    Text eB = Text(); eB.text("b"); ac.add(eB);
    Text eA = Text(); eA.text("a"); ac.add(eA);
    Text eL = Text(); eL.text("l"); ac.add(eL);
    Text eR = Text(); eR.text("r"); ac.add(eR);
    Text eO = Text(); eO.text("o"); ac.add(eO);
    Array<Text> floats = [eB, eA, eL, eR, eO];
    Array<AnchorEdge> edges = [AnchorEdge::Below, AnchorEdge::Above,
                               AnchorEdge::LeftOf, AnchorEdge::RightOf, AnchorEdge::Over];
    for (int i in 0..floats.length() - 1) {
        Position p = floats[i].position();
        p.method = PositionMethod::Absolute;
        p.w = 3; p.h = 1;
        p.anchorTo(tgt, edges[i]);
    }
    ac.measure(Size(40, 24));
    ac.arrange(Rect(Point(0, 0), Size(40, 24)));
    xy("below", eB.box);                      // below 10,7  (t.x, t.bottom)
    xy("above", eA.box);                      // above 10,4  (t.x, t.y - oh)
    xy("leftof", eL.box);                     // leftof 7,5  (t.x - ow, t.y)
    xy("rightof", eR.box);                    // rightof 14,5 (t.right, t.y)
    xy("over", eO.box);                       // over 10,5   (t.x, t.y)

    tgp.x = 20; tgp.y = 8;                    // move the target: box now (20,8,4,2)
    ac.measure(Size(40, 24));
    ac.arrange(Rect(Point(0, 0), Size(40, 24)));
    xy("below2", eB.box);                     // below2 20,10 (tracked the move)
    xy("rightof2", eR.box);                   // rightof2 24,8

    Position pB = eB.position();
    pB.clearAnchor();                         // no anchor -> stored desired coords
    pB.x = 1; pB.y = 2;
    ac.measure(Size(40, 24));
    ac.arrange(Rect(Point(0, 0), Size(40, 24)));
    xy("cleared", eB.box);                    // cleared 1,2

    // ---- popover over the overlay stack ----------------------------------
    section("popover");
    Text anchor = Text(); anchor.text("anchor"); app.add(anchor);
    app.measure(Size(40, 24));
    app.arrange(Rect(Point(0, 0), Size(40, 24)));
    DomNode anchorNode = DomNode(anchor, doc);
    Text panel = Text(); panel.text("panel");
    DomNode panelNode = DomNode(panel, doc);
    console.writeln(app.overlayCount());      // 0
    DomNode host = panelNode.popover(anchorNode, AnchorEdge::Below);
    console.writeln(app.overlayCount());      // 1
    host.raw().arrange(Rect(Point(0, 0), Size(40, 24)));
    console.writeln(panel.box.x() == anchor.box.x());       // true
    console.writeln(panel.box.y() == anchor.box.bottom());  // true
    host.dismiss();
    console.writeln(app.overlayCount());      // 0

    section("done");
}
