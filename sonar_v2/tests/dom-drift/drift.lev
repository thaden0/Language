uses Sonar;
uses Sonar::Dom;

// D02 M5 — the tier-equivalence / drift harness (design §6 M5, §7.1).
// ONE corpus file (every registry tag, every typed-attr shape) feeds all
// three tiers — the comptime import folds to an ordinary string literal by
// pass 2 (LA-20), so the same bytes drive:
//   A. `dom!(corpus)`                — comptime expansion (M4),
//   B. `buildMarkup(corpus, doc)`    — runtime string tier (M1–M3),
//   C. `FlexContainer(import(...))`  — asset/ctor tier (probe D-P7: import()
//                                      directly in a ctor argument),
// and the serializer must print byte-identical trees for all three (each
// tier builds against its own Document so ids cannot collide).

comptime string corpus = import("corpus.sonar");

// the dom! holes' capture targets: a bare global (the full-fidelity D05
// path) and a typed (int) hole. Assigned in main, not at the declaration —
// top-level initializer order is a documented footgun.
string filename = "";
int build_count = 0;

void section(string s) { console.writeln("== " + s + " =="); }

// Recursive detach (the v1 teardown-test mechanic). Container.add attaches
// unconditionally — even into a detached tree — so the corpus's
// progress/spinner ctor-registered timers arm real process timers on build;
// without a run loop nothing cancels them and the process would outlive
// main. Detaching every node releases the bound tokens.
void teardown(IComponent c) {
    for (IComponent kid in c.__sonarChildren()) teardown(kid);
    c.__sonarDetach();
}

// a user component: Capitalized tag + pass-through setter at the dom! tier
class Gizmo : Component {
    string spin_ = "";
    void setSpin(string v) { spin_ = v; }
}

class DriftHost {
    // id-bound fields (the T06 field-binding rule: `id="x"` assigns
    // `this.x` alongside the registerId that __recordBuild performs)
    FlexContainer shell;
    Input name;
    Button okBtn;
    Button saveBtn;

    Array<string> perms = ["read", "write"];
    bool showHelp = true;
    int saves = 0;

    IComponent buildShared() { return dom!(corpus); }

    // dom!-tier-only surface: {expr} attrs, $for/$if/$else, on: handlers,
    // Capitalized user tags, binding holes over globals.
    IComponent buildDomOnly() {
        return dom!(`
            <flex width={Constraint::Fixed(30)} hidden={!this.showHelp}>
                build {{build_count}}
                $for p in this.perms {
                    <checkbox label={p}/>
                }
                $if this.showHelp {
                    <span>help</span>
                } $else {
                    <span>no help</span>
                }
                <button id="saveBtn" on:press={this.onSave}>Save</button>
                <Gizmo spin="3"/>
            </flex>
        `);
    }

    IComponent buildMulti() { return dom!(`<span>a</span><span>b</span>`); }

    void onSave() { saves = saves + 1; }
}

void main() {
    SonarApp app = SonarApp();
    Document docA = app.document();
    filename = "notes.txt";
    build_count = 7;

    DriftHost host = DriftHost();

    // tier A: dom! (expansion runs against the current Document). The trees
    // stay DETACHED throughout: the corpus spinner's ctor-registered timer
    // would arm on attach and keep the process alive after main returns
    // (the run-loop is out of scope here; serialization needs no attach).
    IComponent a = host.buildShared();

    // tier B: runtime parse of the same bytes
    Document docB = Document(app);
    docB.set("filename", "notes.txt");
    IComponent b = buildMarkup(corpus, docB);

    // tier C: asset/ctor tier. Probe D-P7 is RED — `import()` spliced
    // directly into a ctor argument is NOT comptime-folded (it reaches the
    // runtime prelude and throws LA-20); the design's documented fallback
    // is the T08 comptime-global shape (`corpus` above), cosmetic only.
    // The ctor is a fragment host: the corpus root is its first child.
    Document docC = Document(app);
    docC.set("filename", "notes.txt");
    __setCurrentDocument(docC);
    FlexContainer wrap = FlexContainer(corpus);
    __setCurrentDocument(docA);

    string sa = docA.outerMarkup(a);
    string sb = docB.outerMarkup(b);
    string sc = docC.outerMarkup(wrap.children()[0]);

    section("tier A serialized (dom!)");
    console.writeln(sa);
    section("tier equivalence (same markup -> same tree, all tiers)");
    console.writeln(sa == sb);
    console.writeln(sa == sc);

    section("id field bindings");
    console.writeln(host.name.placeholder);
    console.writeln(host.okBtn.label);
    console.writeln(host.shell.children().length());

    section("registry reverse-match (post-D03 rows)");
    console.writeln(registry().tagMatch(FlexContainer()));
    console.writeln(registry().tagMatch(Bar()));
    console.writeln(registry().tagMatch(Text()));

    section("dom!-only payload");
    IComponent d = host.buildDomOnly();
    console.writeln(docA.outerMarkup(d));
    // the $for's label={p} expr attrs (not serialized — {expr} has no meta row)
    if (d is Container) {
        Container dc = d;
        IComponent c1 = dc.children()[2];
        if (c1 is CheckBox) { CheckBox cb = c1; console.writeln(cb.label); }
        IComponent c2 = dc.children()[3];
        if (c2 is CheckBox) { CheckBox cb = c2; console.writeln(cb.label); }
    }
    host.saveBtn.fireKey(KeyEvent(KeyCode::Enter, std::charFromCode(0), 0));
    console.writeln(host.saves);

    section("fragment auto-wrap");
    IComponent m = host.buildMulti();
    console.writeln(m is FlexContainer);
    if (m is Container) { Container mc = m; console.writeln(mc.children().length()); }

    teardown(a); teardown(b); teardown(wrap); teardown(d); teardown(m);
}
