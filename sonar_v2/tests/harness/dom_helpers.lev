// Sonar DOM Test Helpers (techdesign-08 M1) — DOM-aware scripted-session
// helpers for the SonarTest harness. A new file in tests/harness/ that extends
// SonarTest with selector-driven helpers; the landed harness files
// (assert.lev, scripted_input.lev) are NOT modified in place — this file
// adds to the SonarTest namespace, the landed extension pattern.
//
// Every helper pumps once after delivery (the deterministic one-chunk-per-pump
// model). `click` uses SGR mouse bytes: \x1b[<b;x;yM (press) / \x1b[<b;x;ym
// (release), 1-based coords. The encode->decode round-trip extends the chord
// encoder's discipline (scripted_input.lev §3) to mice.
//
// Helpers on a plain App: `q`/`click` need a Document via Dom::document().
// If no SonarApp is running, Dom::document() throws the E-D4 no-current-
// Document error (message points at SonarApp). Landed-suite tests keep using
// the landed harness untouched.
uses Sonar;
uses Sonar::Dom;

namespace SonarTest {

    // ---- encodeMouse (the chord encoder's mouse twin) -----------------------
    // Encode a mouse event into SGR extended mouse protocol bytes.
    //   button: 0 = left, 1 = middle, 2 = right.
    //   x, y:   1-based column and row (terminal screen coordinates, not 0-based).
    //   press:  true = button press (final byte 'M'), false = release (final 'm').
    // Format: ESC [ < b ; x ; y M/m — the standard xterm SGR mouse extension.
    // The decoder in the Sonar input stack reverses this exactly; the round-trip
    // test in dom-drift tier 2 verifies byte-for-byte agreement.
    string encodeMouse(int x, int y, int button, bool press) {
        string suffix = press ? "M" : "m";
        return csi("<" + button.toString() + ";" + x.toString() + ";" + y.toString() + suffix);
    }

    // ---- q — selector query via the app's Document -------------------------
    // DomNode q(App app, string selector): query the current Document; throws
    // SonarDomException on miss (the D-C2 §12.6 loudness rule, same as
    // DomNode.query / SonarApp.query). The `app` root is used as the query root
    // so all descendants of the app are searched (mirrors SonarApp.queryAll).
    DomNode q(App app, string selector) {
        Document doc = Dom::document();
        return DomNode(queryStr(doc, app, selector), doc);
    }

    // ---- click — center-of-box SGR mouse Press+Release ----------------------
    // Feeds press+release as a single chunk (one chunk per pump, deterministic),
    // delivers it, and pumps once. The center is computed from the component's
    // ARRANGED box (live screen coordinates, 0-based from the renderer's origin)
    // then converted to 1-based SGR coords. A node with zero width or height is
    // clicked at its origin + 1.
    void click(App app, string selector) {
        Document doc = Dom::document();
        IComponent node = queryStr(doc, app, selector);
        Rect b = node.box;
        // Center, converting from 0-based box coords to 1-based SGR coords.
        int halfW = b.w() / 2;
        int halfH = b.h() / 2;
        int cx = b.x() + halfW + 1;
        int cy = b.y() + halfH + 1;
        string bytes = encodeMouse(cx, cy, 0, true) + encodeMouse(cx, cy, 0, false);
        ScriptedInput si = SonarTest::input();
        si.feed(bytes);
        si.deliverNext();
        app.pumpOnce();
    }

    // ---- type — click-to-focus then text bytes --------------------------------
    // Clicks the selector (focusing it) then feeds the text and pumps once.
    // Two pumps total: one from click, one from the text delivery.
    void type(App app, string selector, string text) {
        SonarTest::click(app, selector);
        ScriptedInput si = SonarTest::input();
        si.feed(text);
        si.deliverNext();
        app.pumpOnce();
    }

    // ---- chord — DOM hotkey grammar -> encoded bytes -> pump ----------------
    // Normalizes `spec` via Dom::normalizeHotkey (the `^+s`-style → canonical
    // `C-S-s` translation, D04 §3) then encodes via SonarTest::encodeChord
    // (scripted_input.lev), feeds the chunk, and pumps once. This is how
    // DOM hotkey attrs ("^f", "^o", "^+s") are driven in tests — they go
    // through the same normalization the DOM applies at bind time, then through
    // the same encoder as the chord helpers, so tests exercise the real path.
    void chord(App app, string spec) {
        string encoded = SonarTest::encodeChord(Dom::normalizeHotkey(spec));
        ScriptedInput si = SonarTest::input();
        si.feed(encoded);
        si.deliverNext();
        app.pumpOnce();
    }

    // ---- textOf — display-text channel of a matched node -------------------
    string textOf(App app, string selector) {
        return SonarTest::q(app, selector).text();
    }

    // ---- expectText — eq() sugar over textOf --------------------------------
    // Asserts textOf(app, sel) == want, printing "ok <label>" or "FAIL <label>".
    // Uses SonarTest::eq (assert.lev) so failures flip the process exit code.
    void expectText(App app, string sel, string want, string label) {
        string got = SonarTest::textOf(app, sel);
        SonarTest::eq(got, want, label);
    }

}
