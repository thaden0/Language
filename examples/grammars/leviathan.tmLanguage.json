{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Leviathan",
  "scopeName": "source.leviathan",
  "fileTypes": ["lev", "ext"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#module-access" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.leviathan",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.leviathan" }
          }
        },
        {
          "name": "comment.block.leviathan",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.leviathan" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.leviathan" }
          }
        }
      ]
    },

    "attributes": {
      "comment": "Attributes: @Name, @Ns::Name, @Ns::Name(args) — §6.9",
      "patterns": [
        {
          "match": "(@)\\s*([A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.leviathan" },
            "2": { "name": "entity.name.function.decorator.leviathan" }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        { "include": "#string-triple-double" },
        { "include": "#string-triple-single" },
        { "include": "#string-raw" },
        { "include": "#string-double" },
        { "include": "#string-single" },
        { "include": "#quasiquote" }
      ]
    },

    "string-triple-double": {
      "comment": "Multiline string \"\"\"...\"\"\" — escapes + ${} interpolation apply (§1.4)",
      "name": "string.quoted.triple.double.leviathan",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.leviathan" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.leviathan" }
      },
      "patterns": [
        { "include": "#string-escapes" },
        { "include": "#interpolation" }
      ]
    },

    "string-triple-single": {
      "comment": "Multiline string '''...''' — escapes + ${} interpolation apply (§1.4)",
      "name": "string.quoted.triple.single.leviathan",
      "begin": "'''",
      "end": "'''",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.leviathan" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.leviathan" }
      },
      "patterns": [
        { "include": "#string-escapes" },
        { "include": "#interpolation" }
      ]
    },

    "string-raw": {
      "comment": "Raw string r\"...\" / r'...' — no escapes, no interpolation, single-line (§1.4)",
      "patterns": [
        {
          "name": "string.quoted.raw.double.leviathan",
          "begin": "r\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.leviathan" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.leviathan" }
          }
        },
        {
          "name": "string.quoted.raw.single.leviathan",
          "begin": "r'",
          "end": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.leviathan" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.leviathan" }
          }
        }
      ]
    },

    "string-double": {
      "name": "string.quoted.double.leviathan",
      "begin": "\"",
      "end": "\"|(?<!\\\\)$",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.leviathan" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.leviathan" }
      },
      "patterns": [
        { "include": "#string-escapes" },
        { "include": "#interpolation" }
      ]
    },

    "string-single": {
      "comment": "Single-quoted literal — a string that may target-type to char (§1.4)",
      "name": "string.quoted.single.leviathan",
      "begin": "'",
      "end": "'|(?<!\\\\)$",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.leviathan" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.leviathan" }
      },
      "patterns": [
        { "include": "#string-escapes" },
        { "include": "#interpolation" }
      ]
    },

    "quasiquote": {
      "comment": "Quasiquote template `...` with $name holes (§16.5)",
      "name": "string.quoted.template.leviathan",
      "begin": "`",
      "end": "`",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.leviathan" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.leviathan" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.leviathan",
          "match": "\\\\`"
        },
        {
          "comment": "$name hole inside a quasiquote",
          "match": "(\\$)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.definition.template-expression.leviathan" },
            "2": { "name": "variable.other.template.leviathan" }
          }
        }
      ]
    },

    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.unicode.leviathan",
          "match": "\\\\u\\{[0-9A-Fa-f]{1,6}\\}"
        },
        {
          "name": "constant.character.escape.hex.leviathan",
          "match": "\\\\x[0-9A-Fa-f]{2}"
        },
        {
          "name": "constant.character.escape.leviathan",
          "match": "\\\\[nrt0\\\\\"']"
        },
        {
          "comment": "Any other \\<c> passes c through literally (§1.4)",
          "name": "constant.character.escape.leviathan",
          "match": "\\\\."
        }
      ]
    },

    "interpolation": {
      "comment": "${ expr } interpolation hole (F4) — the expression re-uses the whole grammar",
      "name": "meta.interpolation.leviathan",
      "begin": "\\$\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.leviathan" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.leviathan" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#types" },
        { "include": "#module-access" },
        { "include": "#function-call" },
        { "include": "#operators" },
        { "include": "#punctuation" }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "comment": "Float: integer '.' fractional, underscores allowed in each run (§1.4)",
          "name": "constant.numeric.float.leviathan",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "comment": "Hexadecimal integer 0x.. (underscores allowed)",
          "name": "constant.numeric.integer.hexadecimal.leviathan",
          "match": "\\b0[xX][0-9A-Fa-f][0-9A-Fa-f_]*\\b"
        },
        {
          "comment": "Binary integer 0b.. (underscores allowed)",
          "name": "constant.numeric.integer.binary.leviathan",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "comment": "Decimal integer (underscores allowed)",
          "name": "constant.numeric.integer.decimal.leviathan",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.leviathan",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.leviathan",
          "match": "\\bfalse\\b"
        },
        {
          "comment": "None — the unit absence value; T? is sugar for T | None (§2.3)",
          "name": "constant.language.none.leviathan",
          "match": "\\bNone\\b"
        },
        {
          "comment": "Special float constants exposed on the float type, e.g. float::NaN / float::fromBits",
          "match": "\\b(float)\\s*(::)\\s*(NaN|Infinity|MAX|MIN|Epsilon|fromBits|toBits)\\b",
          "captures": {
            "1": { "name": "support.type.primitive.leviathan" },
            "2": { "name": "punctuation.accessor.namespace.leviathan" },
            "3": { "name": "constant.language.float.leviathan" }
          }
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "comment": "class / struct / enum / interface declaration — capture the type name",
          "match": "\\b(class|struct|enum|interface)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.leviathan" },
            "2": { "name": "entity.name.type.leviathan" }
          }
        },
        {
          "comment": "namespace declaration — capture the (possibly qualified) namespace name",
          "match": "\\b(namespace)\\s+([A-Za-z_][A-Za-z0-9_:]*)",
          "captures": {
            "1": { "name": "storage.type.namespace.leviathan" },
            "2": { "name": "entity.name.namespace.leviathan" }
          }
        },
        {
          "comment": "Constructor: new Name(...) — §4",
          "match": "\\b(new)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.new.leviathan" },
            "2": { "name": "entity.name.function.constructor.leviathan" }
          }
        },
        {
          "comment": "attribute declaration (contextual keyword) — §6.9",
          "match": "\\b(attribute)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.attribute.leviathan" },
            "2": { "name": "entity.name.type.attribute.leviathan" }
          }
        },
        {
          "comment": "rule / macro declaration (contextual keywords) — §16.5",
          "match": "\\b(rule|macro)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.metaprogramming.leviathan" },
            "2": { "name": "entity.name.function.metaprogramming.leviathan" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "comment": "Control flow (§1.3)",
          "name": "keyword.control.leviathan",
          "match": "\\b(if|else|while|for|do|return|break|continue|match|is|try|catch|throw|await|in)\\b"
        },
        {
          "comment": "Storage / declaration keywords",
          "name": "storage.type.leviathan",
          "match": "\\b(var|let|const|class|struct|enum|interface|namespace)\\b"
        },
        {
          "comment": "Modifiers and accessors",
          "name": "storage.modifier.leviathan",
          "match": "\\b(public|private|readonly|weak|mutating|distinct|static|new|get|set|comptime|using)\\b"
        },
        {
          "comment": "Dependency-injection / module keywords",
          "name": "keyword.other.di.leviathan",
          "match": "\\b(bind|inject|use|uses)\\b"
        },
        {
          "comment": "Metaprogramming contextual keywords (§16.5)",
          "name": "keyword.other.metaprogramming.leviathan",
          "match": "\\b(attribute|rule|macro|expand|generates|satisfies|reflect|where)\\b"
        },
        {
          "name": "variable.language.this.leviathan",
          "match": "\\bthis\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "comment": "Primitive value types (the object mask) — §2.2",
          "name": "support.type.primitive.leviathan",
          "match": "\\b(int|string|bool|float|char|byte|void|any|never)\\b"
        },
        {
          "comment": "Built-in container / library types (canonical generics)",
          "name": "support.class.builtin.leviathan",
          "match": "\\b(Array|Map|Set|List|Dict|Pair|Range|Channel|Stream|Task|TaskGroup|Result|Option)\\b"
        },
        {
          "comment": "Type name in a generic instantiation position, e.g. Array<T> / Map<K, V>",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\s*(?=<)",
          "captures": {
            "1": { "name": "entity.name.type.leviathan" }
          }
        }
      ]
    },

    "module-access": {
      "patterns": [
        {
          "comment": "Namespace / module / enum member access: Name:: — §3",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(::)",
          "captures": {
            "1": { "name": "entity.name.namespace.leviathan" },
            "2": { "name": "punctuation.accessor.namespace.leviathan" }
          }
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "comment": "Function / method definition or call: an identifier immediately before '('",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.leviathan" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.leviathan",
          "match": "=>"
        },
        {
          "comment": "Range operator (inclusive) — §1.4",
          "name": "keyword.operator.range.leviathan",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.assignment.compound.leviathan",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.comparison.leviathan",
          "match": "==|!=|<=|>=|<(?![<])|>(?![>])"
        },
        {
          "name": "keyword.operator.logical.leviathan",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.leviathan",
          "match": "<<|>>|\\^|~|&|\\|"
        },
        {
          "comment": "Nullish coalescing (??), optional chaining (?.), optional/ternary (?) — §2.3",
          "name": "keyword.operator.optional.leviathan",
          "match": "\\?\\?|\\?\\.|\\?"
        },
        {
          "name": "keyword.operator.arithmetic.leviathan",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.leviathan",
          "match": "="
        },
        {
          "name": "keyword.operator.accessor.leviathan",
          "match": "::|\\."
        }
      ]
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.terminator.statement.leviathan", "match": ";" },
        { "name": "punctuation.separator.comma.leviathan", "match": "," },
        { "name": "punctuation.separator.colon.leviathan", "match": ":" },
        { "name": "punctuation.section.parens.begin.leviathan", "match": "\\(" },
        { "name": "punctuation.section.parens.end.leviathan", "match": "\\)" },
        { "name": "punctuation.section.brackets.begin.leviathan", "match": "\\[" },
        { "name": "punctuation.section.brackets.end.leviathan", "match": "\\]" },
        { "name": "punctuation.section.braces.begin.leviathan", "match": "\\{" },
        { "name": "punctuation.section.braces.end.leviathan", "match": "\\}" }
      ]
    }
  }
}
