  Run / helm.build [^B]  — Build Workspace
  Run / helm.run [F5]  — Run
  Run / helm.stop [S-F5]  — Stop
  Run / helm.test [^;]  — Run Tests
  Run / helm.runEngine  — Run (current engine)
  Run / helm.engine.oracle  — Engine: oracle
  Run / helm.engine.ir  — Engine: ir
  Run / helm.engine.llvm  — Engine: llvm
  View / helm.togglePanel [^`]  — Toggle Panel
  View / helm.palette [^P]  — Command Palette…
  File / helm.save [^S]  — Save
  File / helm.quit [^Q]  — Quit
