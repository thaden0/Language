// Sibling example: the tests live in a SEPARATE project that depends on both
// the app (../app) and harpoon (../../..). Fast local iteration — rebuilding
// this project does not rebuild the app. The @Test classes here mirror the
// inline example's exactly, so the report is byte-identical: discovery is
// location-agnostic (the trigger is `uses harpoon`, not the file's path).
uses harpoon;
uses calc;

class CalcTests {
    @Test void addsPositives()  { harpoon::assertEqual(5, calc::add(2, 3)); }
    @Test void subtracts()      { harpoon::assertEqual(1, calc::sub(4, 3)); }
    @Test void multiplies()     { harpoon::assertEqual(12, calc::mul(3, 4)); }
    @Test @Skip void wip()      { }
}

harpoon::main();
