// Track 01 F1: real int shift/xor/complement — `<<`/`>>` were object transfer
// operators only; on int they silently typed as the operand and produced a
// runtime void (curl-design §2.8#1). Now int-op-int -> int, resolved by type
// exactly like `+` (an object left operand still dispatches its (<<)/(>>)
// method — see block_ns_import.ext-adjacent object-operator corpus for that
// path; this file is the primitive path only).
console.writeln(1 << 4);           // 16
console.writeln(256 >> 4);         // 16
console.writeln(5 ^ 3);            // 6
console.writeln(~0);               // -1
console.writeln(~5);               // -6
console.writeln(1 << 0);           // 1 (boundary: count 0)
console.writeln(1 << 63);          // INT64_MIN (boundary: count 63)
console.writeln(0 - 1 >> 63);      // -1 (arithmetic shift sign-extends)
console.writeln(1 << 4 >> 2);      // 4 (left-assoc chaining)
console.writeln(~(~5));            // 5 (double complement)
int x = 5;
int y = x << 2 >> 1 ^ 3 & 1 | 2;   // precedence smoke test: & tighter than ^ than |
console.writeln(y);
try {
    console.writeln(1 << 64);      // out-of-range count -> RuntimeException
} catch (RuntimeException e) {
    console.writeln("caught: " + e.message);
}
try {
    console.writeln(1 >> (0 - 1)); // negative count -> RuntimeException
} catch (RuntimeException e) {
    console.writeln("caught: " + e.message);
}
