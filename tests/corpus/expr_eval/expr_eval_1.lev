// LA-31 Stage 1 §3.2 — hand-built-tree corpus + the canonical expr::eval walker.
// Reification does not exist yet (Stage 2); this proves the node taxonomy is
// constructible and walkable BY HAND, and it is the exact `eval` the Stage 3
// differential corpus embeds. `eval` is checked user code (ruling R14), never
// prelude. Two mechanical syntax corrections vs. the design's §3.1 verbatim
// text, both semantics-preserving (logged in techdesign-01 §5):
//   (a) `X as T` reads become bare reads of the match-narrowed `X` (no cast
//       operator exists in the language);
//   (b) bare `=> return E;` match arms become braced `=> { return E; }` (a
//       statement-bodied arm requires a block; an expr arm takes no `return`).
// The §3.1-referenced `asStr` helper (undefined there) is supplied here.

// ---- expr::eval — reference tree interpreter ----
bool evalTruth(string | int | float | bool | None v) {
    match (v) {
        bool => { return v; }
        else => { return false; }
    }
}

string asStr(string | int | float | bool | None v) {
    match (v) {
        string => { return v; }
        else   => { return ""; }
    }
}

bool dbEq(string | int | float | bool | None a, string | int | float | bool | None b) {
    match (a) {
        None => { match (b) { None => { return true; }  else => { return false; } } }
        int  => { match (b) { int  => { return a == b; } else => { return false; } } }
        float=> { match (b) { float=> { return a == b; } else => { return false; } } }
        bool => { match (b) { bool => { return a == b; } else => { return false; } } }
        string => { match (b) { string => { return a == b; } else => { return false; } } }
    }
}

string | int | float | bool | None dbNum(string op,
        string | int | float | bool | None a, string | int | float | bool | None b) {
    match (a) {
        int => { match (b) { int => {
            int x = a; int y = b;
            if (op == "<")  return x < y;
            if (op == "<=") return x <= y;
            if (op == ">")  return x > y;
            if (op == ">=") return x >= y;
            if (op == "+")  return x + y;
            if (op == "-")  return x - y;
            if (op == "*")  return x * y;
            if (op == "/")  return x / y;
            if (op == "%")  return x % y;
        } else => { } } }
        float => { match (b) { float => {
            float x = a; float y = b;
            if (op == "<")  return x < y;
            if (op == "<=") return x <= y;
            if (op == ">")  return x > y;
            if (op == ">=") return x >= y;
            if (op == "+")  return x + y;
            if (op == "-")  return x - y;
            if (op == "*")  return x * y;
            if (op == "/")  return x / y;
        } else => { } } }
        string => { match (b) { string => {
            if (op == "+") return a + b;
        } else => { } } }
        else => { }
    }
    match (a) { None => { } else => { match (b) { None => { } else => {
        throw RuntimeException("expr::eval: bad operands for " + op); } } } }
    if (op == "<" || op == "<=" || op == ">" || op == ">=") return false;
    return None;
}

string | int | float | bool | None evalNode(
        expr::Node n,
        (Array<string>) => string | int | float | bool | None rec,
        Array<string | int | float | bool | None> binds,
        Array<string | int | float | bool | None> arrayBind0) {
    match (n) {
        expr::Field => { return rec(n.path); }
        expr::Lit   => { return n.v; }
        expr::Bind  => { return binds[n.slot]; }
        expr::Un    => {
            expr::Un u = n;
            string | int | float | bool | None inner = evalNode(u.e, rec, binds, arrayBind0);
            if (u.op == "!") return !evalTruth(inner);
            match (inner) {
                int   => { return 0 - inner; }
                float => { return 0.0 - inner; }
                else  => { return None; }
            }
        }
        expr::Bin   => {
            expr::Bin b = n;
            string | int | float | bool | None lv = evalNode(b.l, rec, binds, arrayBind0);
            string | int | float | bool | None rv = evalNode(b.r, rec, binds, arrayBind0);
            if (b.op == "&&") return evalTruth(lv) && evalTruth(rv);
            if (b.op == "||") return evalTruth(lv) || evalTruth(rv);
            if (b.op == "==") return dbEq(lv, rv);
            if (b.op == "!=") return !dbEq(lv, rv);
            return dbNum(b.op, lv, rv);
        }
        expr::Call  => {
            expr::Call c = n;
            if (c.name == "contains" && c.args.length() == 1) {
                // Array receiver form: receiver is a Bind whose slot carries the
                // marker None in `binds` and whose values live in arrayBind0.
                match (c.recv) {
                    expr::Bind => {
                        string | int | float | bool | None needle =
                            evalNode(c.args[0], rec, binds, arrayBind0);
                        int k = 0;
                        while (k < arrayBind0.length()) {
                            if (dbEq(arrayBind0[k], needle)) return true;
                            k = k + 1;
                        }
                        return false;
                    }
                    else => { }
                }
            }
            string recvS = asStr(evalNode(c.recv, rec, binds, arrayBind0));
            string arg0S = asStr(evalNode(c.args[0], rec, binds, arrayBind0));
            if (c.name == "like")       return recvS.like(arg0S);
            if (c.name == "ilike")      return recvS.ilike(arg0S);
            if (c.name == "startsWith") return recvS.startsWith(arg0S);
            if (c.name == "endsWith")   return recvS.endsWith(arg0S);
            if (c.name == "contains")   return recvS.contains(arg0S);
            throw RuntimeException("expr::eval: non-whitelisted call " + c.name);
        }
        else => { throw RuntimeException("expr::eval: unhandled node"); }
    }
}
// ---- end expr::eval ----

// --- fixtures: two records implemented as lambda accessors ---
(Array<string>) => string | int | float | bool | None get1 = (path) => {
    if (path[0] == "active") return true;
    if (path[0] == "name")   return "Ada";
    if (path[0] == "age")    return 30;
    return None;
};

(Array<string>) => string | int | float | bool | None get2 = (path) => {
    if (path[0] == "active") return false;
    if (path[0] == "name")   return "Bob";
    if (path[0] == "age")    return 70;
    return None;
};

// --- tree 1: (u) => u.active && u.name.like("A%") ---
expr::Node likeArg = expr::Lit("A%");
Array<expr::Node> likeArgs = [likeArg];
expr::Node tree1 = expr::Bin("&&",
    expr::Field(["active"]),
    expr::Call("like", expr::Field(["name"]), likeArgs));

// --- tree 2: (u) => u.age >= lo && u.age < hi  (lo=Bind(0), hi=Bind(1)) ---
expr::Node tree2 = expr::Bin("&&",
    expr::Bin(">=", expr::Field(["age"]), expr::Bind(0)),
    expr::Bin("<",  expr::Field(["age"]), expr::Bind(1)));

Array<string | int | float | bool | None> noBinds = [];
string | int | float | bool | None lo = 18;
string | int | float | bool | None hi = 65;
Array<string | int | float | bool | None> ageBinds = [lo, hi];
Array<string | int | float | bool | None> noArr = [];

console.writeln("t1r1:" + evalTruth(evalNode(tree1, get1, noBinds, noArr)).toString());
console.writeln("t1r2:" + evalTruth(evalNode(tree1, get2, noBinds, noArr)).toString());
console.writeln("t2r1:" + evalTruth(evalNode(tree2, get1, ageBinds, noArr)).toString());
console.writeln("t2r2:" + evalTruth(evalNode(tree2, get2, ageBinds, noArr)).toString());

// --- else-arm safety: a bare expr::Node() must reach the throwing else arm ---
void probeElse() {
    try {
        expr::Node bare = expr::Node();
        evalNode(bare, get1, noBinds, noArr);
        console.writeln("matchElse:NOTHROW");
    } catch (RuntimeException e) {
        console.writeln("matchElse:ok");
    }
}
probeElse();
