bool hit(string p, string flags, string s) => regex::programIsMatch(regex::compileProgram(p, flags), s);
int vectors() {
    int n = 0;
    if (hit("", "", "")) n = n + 1;
    if (hit("", "", "abc")) n = n + 1;
    if (hit("abc", "", "xxabcxx")) n = n + 1;
    if (!hit("abc", "", "abx")) n = n + 1;
    if (hit("a|b", "", "b")) n = n + 1;
    if (hit("ab|cd", "", "xxcd")) n = n + 1;
    if (hit("(ab|a)c", "", "ac")) n = n + 1;
    if (hit("(?:ab)+", "", "abab")) n = n + 1;
    if (hit("a?b", "", "b")) n = n + 1;
    if (hit("a*b", "", "aaaaab")) n = n + 1;
    if (hit("a+b", "", "ab")) n = n + 1;
    if (!hit("a+b", "", "b")) n = n + 1;
    if (hit("a{2}", "", "aa")) n = n + 1;
    if (!hit("a{2}", "", "a")) n = n + 1;
    if (hit("a{2,4}", "", "aaa")) n = n + 1;
    if (hit("a{2,}", "", "aaaaa")) n = n + 1;
    if (hit(".", "", "x")) n = n + 1;
    if (!hit(".", "", "\n")) n = n + 1;
    if (hit(".", "s", "\n")) n = n + 1;
    if (hit("[a-z]", "", "m")) n = n + 1;
    if (!hit("[a-z]", "", "M")) n = n + 1;
    if (hit("[a-z]", "i", "M")) n = n + 1;
    if (hit("abc", "i", "--ABC--")) n = n + 1;
    if (hit("[^a-z]", "", "9")) n = n + 1;
    if (hit("[0-9_]", "", "_")) n = n + 1;
    if (hit("\\d+", "", "x123")) n = n + 1;
    if (hit("\\D+", "", "123x")) n = n + 1;
    if (hit("\\w+", "", "_a9")) n = n + 1;
    if (hit("\\W+", "", "abc!")) n = n + 1;
    if (hit("\\s+", "", "x \t")) n = n + 1;
    if (hit("\\S+", "", "  x")) n = n + 1;
    if (hit("^abc$", "", "abc")) n = n + 1;
    if (!hit("^abc$", "", "xabc")) n = n + 1;
    if (hit("^abc$", "m", "x\nabc\ny")) n = n + 1;
    if (hit("\\bcat\\b", "", "a cat!")) n = n + 1;
    if (!hit("\\bcat\\b", "", "scat")) n = n + 1;
    if (hit("\\Bcat", "", "scat")) n = n + 1;
    if (hit("a\\.b", "", "a.b")) n = n + 1;
    if (hit("a\\*b", "", "a*b")) n = n + 1;
    if (hit("a\\nb", "", "a\nb")) n = n + 1;
    if (hit("[\\dA-F]+", "", "B29")) n = n + 1;
    if (hit("[\\D]+", "", "123x")) n = n + 1;
    if (hit("(?:)*", "", "abc")) n = n + 1;
    if (hit("(a*)*", "", "aaa")) n = n + 1;
    if (hit("a+?", "", "aaa")) n = n + 1;
    if (hit("(?<word>\\w+)", "", "hello")) n = n + 1;
    if (hit("^[a-z0-9_]{3,16}$", "", "valid_123")) n = n + 1;
    if (!hit("^[a-z0-9_]{3,16}$", "", "NO")) n = n + 1;
    if (hit("error: \\d+", "", "prefix error: 42 tail")) n = n + 1;
    if (!hit("error: \\d+", "", "error: nope")) n = n + 1;
    if (hit("x[0-9]+z", "", "skip x123z")) n = n + 1;
    return n;
}
console.writeln(vectors());
