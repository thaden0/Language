class Point {
    public int x;
    public int y;
    public string label;
    void move(int dx, int dy) {
        x = x + dx;
        y = y + dy;
    }
    string describe() => label + ": " + x + "," + y;
}

Point p = Point();
p.x = 3;
p.y = 4;
p.label = "origin-ish";
p.move(10, 20);
console.writeln(p.x);
console.writeln(p.y);
console.writeln(p.describe());
