// Track 08 system natives (interpreters): property checks only — no golden
// values for time/random (design M3), so this file stays environment-neutral.
// The environment-dependent bits (env PATH, DNS localhost, dir round-trip) live
// in tests/run_sysnatives.sh.

// F2 monotonic: a later read never precedes an earlier one.
int a = std::sysMonotonic();
int b = std::sysMonotonic();
console.writeln((b >= a).toString());

// F2 random: requested length is honoured; n<=0 is the empty string.
console.writeln(std::sysRandom(0).length().toString());
console.writeln(std::sysRandom(24).length().toString());

// F4 isatty: whatever the value, it is a stable bool (equal to itself).
bool t = std::sysIsTty(1);
console.writeln((t == t).toString());

// F1 env: an unset variable is None (distinct from set-but-empty, §9).
console.writeln((env::get("LEVIATHAN_NOPE_XYZ_123") == None).toString());

// F3 listDir: a path that is not a directory is None (distinct from []).
console.writeln((std::sysListDir("/nonexistent/path/xyz/123") == None).toString());

// request-stat-isdir.md: field 3 = isDir. "/" always exists and is a
// directory; a nonexistent path reports -1 (not 1, not 0). std::isDir wraps
// field 3 == 1 directly; the file-vs-directory and unreadable-directory
// edges (environment-dependent) live in tests/run_sysnatives.sh.
console.writeln((std::sysStat("/", 3) == 1).toString());
console.writeln((std::sysStat("/nonexistent/path/xyz/123", 3) == -1).toString());
console.writeln(std::isDir("/").toString());
console.writeln(std::isDir("/nonexistent/path/xyz/123").toString());
