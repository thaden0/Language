// Labeled break/continue (techdesign-labeled-break-continue.md). All four
// loop kinds carry a label; break/continue name a label on an ENCLOSING loop
// to unwind/restart it from arbitrary nesting depth. Also: label targeting
// from inside if/match/try bodies, sibling label reuse, and unlabeled forms
// mixed in (regression, Track 02 F1).

// --- while: labeled break out of two nested whiles ---
void whileTest() {
    int i = 0;
    outer: while (i < 5) {
        int j = 0;
        while (j < 5) {
            if (i == 2 && j == 2) break outer;
            console.writeln("w " + i.toString() + " " + j.toString());
            j = j + 1;
        }
        i = i + 1;
    }
}

// --- do-while: labeled continue back to the outer do-while's condition,
// jumping past the rest of the outer body (the "d-after-inner" print) ---
void doWhileTest() {
    int i = 0;
    outer: do {
        i = i + 1;
        int j = 0;
        do {
            j = j + 1;
            if (i == 2 && j == 2) continue outer;
            console.writeln("d " + i.toString() + " " + j.toString());
        } while (j < 3);
        console.writeln("d-after-inner " + i.toString());
    } while (i < 3);
}

// --- C-style for: labeled break/continue from the innermost of 3-deep
// nesting, targeting the OUTER and MIDDLE loops respectively ---
void forTest() {
    outer: for (int i = 0; i < 3; i = i + 1) {
        middle: for (int j = 0; j < 3; j = j + 1) {
            for (int k = 0; k < 3; k = k + 1) {
                if (k == 1 && j == 1) continue middle;
                if (i == 2 && j == 0 && k == 0) break outer;
                console.writeln("f " + i.toString() + " " + j.toString() + " " + k.toString());
            }
        }
    }
}

// --- for..in: labeled break/continue from inside a match arm's if/else, and
// labeled continue from inside a try's catch clause ---
void forInTest() {
    outer: for (int i in 1..4) {
        for (int j in 1..3) {
            match (j) {
                2 => { if (i == 3) break outer; else if (i == 1) continue outer; }
                else => { }
            }
            try {
                if (j == 1 && i == 2) throw RuntimeException("boom");
                console.writeln("fi " + i.toString() + " " + j.toString());
            } catch (RuntimeException e) {
                continue outer;
            }
        }
    }
}

// --- sibling label reuse: two SIBLING loops (neither enclosing the other)
// may share the same label — the first pops before the second pushes ---
void siblingTest() {
    L: for (int i = 0; i < 2; i = i + 1) {
        console.writeln("s1 " + i.toString());
        if (i == 1) break L;
    }
    L: for (int i = 0; i < 2; i = i + 1) {
        if (i == 0) { console.writeln("s2 " + i.toString()); continue L; }
        console.writeln("s2-after " + i.toString());
    }
}

// --- unlabeled forms mixed in (regression, Track 02 F1): a LABELED loop's
// UNLABELED break/continue still targets the nearest enclosing loop ---
void unlabeledTest() {
    outer: for (int i = 0; i < 5; i = i + 1) {
        if (i == 3) break;
        if (i == 1) continue;
        console.writeln("u " + i.toString());
    }
}

whileTest();
doWhileTest();
forTest();
forInTest();
siblingTest();
unlabeledTest();
