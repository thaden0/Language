// M1 pin: struct-in-struct equality recurses into the nested struct's own
// field-wise compare; a mismatch in the inner struct fails the outer compare.
struct Inner { int a; int b; new Inner(int aa, int bb) { a = aa; b = bb; } }
struct Outer { Inner i; string tag; new Outer(Inner ii, string tt) { i = ii; tag = tt; } }
void main() {
    console.writeln(Outer(Inner(1, 2), "x") == Outer(Inner(1, 2), "x"));  // true
    console.writeln(Outer(Inner(1, 2), "x") == Outer(Inner(1, 3), "x"));  // false (inner mismatch)
    console.writeln(Outer(Inner(1, 2), "x") == Outer(Inner(1, 2), "y"));  // false (outer mismatch)
    console.writeln(Outer(Inner(1, 2), "x") != Outer(Inner(1, 3), "x"));  // true
}
main();
