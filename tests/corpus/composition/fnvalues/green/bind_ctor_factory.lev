// Block-scope `bind IFace => Ctor();` (factory-body form) — the sanctioned
// working sibling of red/bind_local_var.lev (#56).
interface ICounter { int next(); }
class Counter : ICounter {
    int n = 0;
    int next() { this.n = this.n + 1; return this.n; }
}
int useCounter(ICounter c) => c.next();
void ctorForm() {
    bind ICounter => Counter();
    console.writeln(useCounter(inject ICounter).toString());
}
ctorForm();
