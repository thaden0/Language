// XFAIL-ELF: the frozen X64Gen backend still leaks the dense IndexStore VALUE
// operand — the struct written into a dense array is heap-allocated (it
// "escapes" per Ownership's stored-by-index rule), its record is memcpy'd into
// the buffer, and the standalone copy is never freed (~64B/iteration). On LLVM
// this is FIXED (guarded green): the store's value operand is a definite fresh
// `CopyVal c=1` temp read only by the store, so codegen routes it to the
// consuming lvrt_idxset_move, which vfrees the dead copy on every path that
// copied the record in (dense/columnar/map) and transfers ownership to the
// slot on the boxed in-range edge. See known_bugs_2.md worktree-agent-a7c3e630889a1bf22-107.
struct Pt {
    int x;
    int y;
}
void run(int n) {
    Pt p;
    Array<Pt> pts;
    for (int i in 0..3) {
        pts = pts.add(p);
    }
    int sink = 0;
    for (int i in 1..n) {
        Pt q;
        q.x = i;
        pts[i - (i / 4) * 4] = q;   // dense set: in place when unique, but q's heap copy leaks
        Pt r = pts[0];
        sink = sink + r.x;
    }
    console.writeln(sink);
}
run(@N@);
