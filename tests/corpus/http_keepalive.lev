// Track 09 F4 (M6): server-side keep-alive — two requests served on ONE
// connection. The raw client sends request 2 only after response 1 arrives
// (buffered-but-serial; v1 does not pipeline). Sockets -> oracle + IR lanes.
class KAClient {
    TcpStream stream;
    HttpServer server;
    string acc = "";
    int got = 0;
    new KAClient(TcpStream s, HttpServer srv) { stream = s; server = srv; }
    void start() {
        KAClient self = this;
        stream.onData((chunk) => self.onData(chunk));
        this.send("/one");
    }
    // no "Connection: close" -> the server keeps the connection alive
    void send(string path) {
        stream << ("GET " + path + " HTTP/1.1\r\nHost: x\r\n\r\n");
    }
    void onData(string chunk) {
        acc = acc + chunk;
        int he = acc.indexOf("\r\n\r\n");
        if (he < 0) return;
        int firstNl = acc.indexOf("\r\n");
        HeaderMap hm = std::parseHeaderLines(acc.subStr(firstNl + 2, he - (firstNl + 2)));
        int cl = std::bodyLenOf(hm);
        int need = cl > 0 ? cl : 0;
        int total = he + 4 + need;
        if (acc.length() < total) return;               // response not fully arrived
        string body = acc.subStr(he + 4, need);
        acc = acc.subStr(total, acc.length() - total);
        got = got + 1;
        console.writeln("resp" + got + " body=" + body + " conn=" + hm.firstOr("Connection", "?"));
        if (got == 1) this.send("/two");
        else { stream.close(); server.stop(); }
    }
}
void run() {
    HttpServer server = HttpServer(8095);
    server.handle((req) => HttpResponse(200, "got " + req.path));
    int fd = std::sysTcpConnect("127.0.0.1", 8095);
    KAClient c = KAClient(TcpStream(fd), server);
    c.start();
    console.writeln("up");
}
run();
