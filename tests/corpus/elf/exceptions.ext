// Exceptions compiled by the PURE backend (own x86-64 + ELF, no g++/libc):
// try/catch by type / base / interface, propagation across calls, runtime
// errors (array bounds), and the uncaught-at-top-level report — the interpreter
// model (a pending-throw flag checked after each call) in raw machine code.
int divide(int a, int b) {
    if (b == 0) throw RuntimeException("division by zero");
    return a / b;
}
void run() {
    try { throw LogicException("bad input"); }
    catch (IException e) { console.writeln("iface: " + e.message); }

    try { int x = divide(1, 0); }
    catch (ILogicException e) { console.writeln("wrong"); }
    catch (IRuntimeException e) { console.writeln("caught: " + e.message); }

    console.writeln(divide(10, 2));

    Array a = [1, 2, 3];
    try { int x = a[9]; }
    catch (RuntimeException e) { console.writeln(e.message); }

    try {
        try { throw RuntimeException("inner"); }
        catch (ILogicException e) { console.writeln("no"); }
    } catch (IException e) { console.writeln("rethrown to outer: " + e.message); }
}
run();
throw LogicException("uncaught at top level");
