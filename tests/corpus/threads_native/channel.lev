// Track 10 M4 (techdesign-threads-2 §3.3): Channel<T> — a single-producer /
// single-consumer conduit — on the SERIAL reference engines (oracle + IR).
// `send` copies the value in (flatten/rebuild §4.4); `receive()` is a Promise<T?>
// that resolves with the next item or None once the channel is closed AND
// drained (F-8). The true lock-free ring + eventfd wakeups are the LLVM leg (M3);
// here the channel is an in-process queue on the one cooperative loop. Output
// stays deterministic: only the consumer (spawning thread) writes (§8).

// 1. ping-pong: a producer worker sends three values and closes; the consumer
//    drains until None. The producer captures the Channel handle — a portal (§6),
//    so both share the one endpoint. receive() parking + send() hand-off is the
//    cooperative scheduling that makes this not deadlock (F-5).
int pingpong() {
    Channel<int> ch = Channel(4, std::overflowBlock());
    Worker<int> producer = std::spawn(() => {
        ch.send(1);
        ch.send(2);
        ch.send(3);
        ch.close();
        return 0;
    });
    int sum = 0;
    bool draining = true;
    while (draining) {
        int? v = await ch.receive();          // fresh binding each turn
        if (v != None) { sum = sum + v; }     // narrows v to int in this arm
        else { draining = false; }            // None = closed and drained (F-8)
    }
    return sum;
}
console.writeln(pingpong());                 // 6

// 2. a struct value crosses by copy: mutating the sender's original after send
//    is not observed by the receiver (the copy-in boundary, acceptance #1-shaped).
struct Point { int x; int y; }
int sendStruct() {
    Channel<Point> ch = Channel(2, std::overflowBlock());
    Point p;
    p.x = 3; p.y = 4;
    ch.send(p);
    p.x = 99;                                // mutate the original after send
    ch.close();
    Point? got = await ch.receive();
    if (got != None) { return got.x + got.y; }
    return 0 - 1;
}
console.writeln(sendStruct());               // 7 (3 + 4), not 103

// 3. the drop policy discards on a full buffer; error throws (loud, §16).
int overflowError() {
    Channel<int> ch = Channel(1, std::overflowError());
    ch.send(1);                              // fills the buffer
    ch.send(2);                              // overflow -> throw
    return 0;
}
try { console.writeln(overflowError()); }
catch (RuntimeException e) { console.writeln(e.message); }   // channel overflow

// 4. send on a closed channel is a loud error.
int closedSend() {
    Channel<int> ch = Channel(2, std::overflowBlock());
    ch.close();
    ch.send(1);
    return 0;
}
try { console.writeln(closedSend()); }
catch (RuntimeException e) { console.writeln(e.message); }   // send on a closed channel

// 5. chained cooperation through a Channel — the sanctioned cross-worker conduit
//    (A-1 §1). A consumer WORKER parks on receive() while the main thread
//    produces, then main awaits the worker's summed result. This is the
//    no-deadlock cooperative property the removed spawn_join case 4 (a captured
//    Worker) used to show, re-demonstrated the sound way: the Channel handle is a
//    portal (§6), shared by both units; the Worker handle never crosses.
int workerConsumes() {
    Channel<int> ch = Channel(4, std::overflowBlock());
    Worker<int> consumer = std::spawn(() => {
        int total = 0;
        bool go = true;
        while (go) {
            int? v = await ch.receive();
            if (v != None) { total = total + v; }
            else { go = false; }
        }
        return total;
    });
    ch.send(10);
    ch.send(20);
    ch.send(30);
    ch.close();
    return await consumer;
}
console.writeln(workerConsumes());           // 60
