// LA-31 Stage 3 §2 row 21 — R12 accepted positions: call argument, local
// bind, `return`, and class field initializer. Four sites, siteId 0..3 in
// source order (R4) — each position appears in the file in exactly that order.
class User { bool active; new User(bool a) { active = a; } }

string dv(string | int | float | bool | None v) {
    match (v) {
        string => { return "str:" + v; }
        int    => { return "int:" + v.toString(); }
        float  => { return "float:" + v.toString(); }
        bool   => { return "bool:" + v.toString(); }
        else   => { return "none"; }
    }
}

string joinPath(Array<string> p) {
    string s = "";
    int i = 0;
    while (i < p.length()) { if (i > 0) { s = s + "."; } s = s + p[i]; i = i + 1; }
    return s;
}

string dumpArgs(Array<expr::Node> a) {
    string s = "";
    int i = 0;
    while (i < a.length()) { if (i > 0) { s = s + ","; } s = s + dump(a[i]); i = i + 1; }
    return s;
}

string dump(expr::Node n) {
    match (n) {
        expr::Bin    => { return "Bin(" + n.op + "," + dump(n.l) + "," + dump(n.r) + ")"; }
        expr::Un     => { return "Un(" + n.op + "," + dump(n.e) + ")"; }
        expr::Field  => { return "Field(" + joinPath(n.path) + ")"; }
        expr::Lit    => { return "Lit(" + dv(n.v) + ")"; }
        expr::Bind   => { return "Bind(" + n.slot.toString() + ")"; }
        expr::Call   => { return "Call(" + n.name + "," + dump(n.recv) + ",[" + dumpArgs(n.args) + "])"; }
        expr::Assign => { return "Assign(" + dump(n.target) + "," + dump(n.value) + ")"; }
        else         => { return "Node"; }
    }
}

string dumpBinds(Array<string | int | float | bool | None> b) {
    string s = "";
    int i = 0;
    while (i < b.length()) { if (i > 0) { s = s + ","; } s = s + dv(b[i]); i = i + 1; }
    return s;
}

void dumpSite(string label, expr::Node tree, Array<string | int | float | bool | None> binds, int site) {
    console.writeln(label + ":" + dump(tree));
    console.writeln(label + "binds:binds=[" + dumpBinds(binds) + "]");
    console.writeln(label + "site:siteId=" + site.toString());
}

string useArg(expr::Expr<(User)=>bool> e) {
    return dump(e.tree) + " site=" + e.siteId.toString();
}

// Site 0 — call argument.
console.writeln("call-arg:" + useArg((u) => u.active));

// Site 1 — local bind.
expr::Expr<(User)=>bool> bound = (u) => u.active;
console.writeln("local-bind:" + dump(bound.tree) + " site=" + bound.siteId.toString());

// Site 2 — `return` against a declared Expr<F> return type.
expr::Expr<(User)=>bool> ret = makeReturned();
console.writeln("return:" + dump(ret.tree) + " site=" + ret.siteId.toString());

// Site 3 — class field initializer.
Spec sp = Spec();
console.writeln("field-init:" + dump(sp.pred.tree) + " site=" + sp.pred.siteId.toString());

expr::Expr<(User)=>bool> makeReturned() { return (u) => u.active; }

class Spec {
    expr::Expr<(User)=>bool> pred = (u) => u.active;
    new Spec() { }
}
