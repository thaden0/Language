// LA-31 Stage 2 — positive smoke 2 (techdesign-02-reifier.md §8.2).
// The same lambda arriving via local bind, `return`, and a class field
// initializer (R12); a capture row `(u) => u.age >= lo` printing binds=[18]
// and Bind(0); and two sites printing siteId 0 then 1 (R4 — source-walk order).
// Byte-identical on oracle + IR + LLVM.

class User {
    bool active;
    string name;
    int age;
    new User(bool a, string n, int g) { active = a; name = n; age = g; }
}

string dv(string | int | float | bool | None v) {
    match (v) {
        string => { return "\"" + v + "\""; }
        int    => { return v.toString(); }
        float  => { return v.toString(); }
        bool   => { return v.toString(); }
        else   => { return "None"; }
    }
}

string joinPath(Array<string> p) {
    string s = "";
    int i = 0;
    while (i < p.length()) { if (i > 0) { s = s + "."; } s = s + p[i]; i = i + 1; }
    return s;
}

string dumpArgs(Array<expr::Node> a) {
    string s = "";
    int i = 0;
    while (i < a.length()) { if (i > 0) { s = s + ","; } s = s + dumpNode(a[i]); i = i + 1; }
    return s;
}

string dumpNode(expr::Node n) {
    match (n) {
        expr::Bin   => { return "Bin(" + n.op + "," + dumpNode(n.l) + "," + dumpNode(n.r) + ")"; }
        expr::Un    => { return "Un(" + n.op + "," + dumpNode(n.e) + ")"; }
        expr::Field => { return "Field(" + joinPath(n.path) + ")"; }
        expr::Lit   => { return "Lit(" + dv(n.v) + ")"; }
        expr::Bind  => { return "Bind(" + n.slot.toString() + ")"; }
        expr::Call  => { return "Call(" + n.name + "," + dumpNode(n.recv) + ",[" + dumpArgs(n.args) + "])"; }
        else        => { return "Node"; }
    }
}

string bindsOf(expr::Expr<(User)=>bool> e) {
    string s = "[";
    int i = 0;
    while (i < e.binds.length()) { if (i > 0) { s = s + ","; } s = s + dv(e.binds[i]); i = i + 1; }
    return s + "]";
}

User ada = User(true, "Ada", 30);

// The two showcase sites are walked first — siteId 0 then 1 (R4). Local-bind
// position; the second captures `lo`, reifying it to Bind(0) with binds=[18].
expr::Expr<(User)=>bool> q0 = (u) => u.active && u.name.like("A%");
console.writeln("q0 tree=" + dumpNode(q0.tree) + " site=" + q0.siteId.toString());

int lo = 18;
expr::Expr<(User)=>bool> q1 = (u) => u.age >= lo;
console.writeln("q1 tree=" + dumpNode(q1.tree) + " binds=" + bindsOf(q1) +
                " site=" + q1.siteId.toString() + " fn=" + q1.fn(ada).toString());

// R12 — the `return` position (site walked later, at the function's body).
expr::Expr<(User)=>bool> q2 = makeAgeGate(21);
console.writeln("q2 tree=" + dumpNode(q2.tree) + " binds=" + bindsOf(q2) +
                " fn=" + q2.fn(ada).toString());

// R12 — the class-field-initializer position (walked at the class body).
Spec sp = Spec();
console.writeln("field tree=" + dumpNode(sp.pred.tree) + " fn=" + sp.pred.fn(ada).toString());

expr::Expr<(User)=>bool> makeAgeGate(int lo) { return (u) => u.age >= lo; }

class Spec {
    expr::Expr<(User)=>bool> pred = (u) => u.active;
    new Spec() { }
}
