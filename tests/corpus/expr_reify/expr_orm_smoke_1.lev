// LA-31 Stage 3 §6 — Track 06 M2 activation smoke: a minimal, in-file
// Query<E>-shaped consumer (NOT the Atlantis package — the language-side
// proof). Asserts: lambdas convert to expr::Expr<F> in fluent-call position,
// the tree walk renders a stable string per site, and siteId distinguishes
// two `.where` sites. Zero ORM M1 code is touched by construction.
//
// bug.md #89 fix: the second `.where` site below is the ask's own headline
// example verbatim (`designs/atlantis/techdesign-06-orm.md:337`,
// `.where((u) => u.active && u.name.like("A%"))`) through this exact
// `Query<E>.where(expr::Expr<(E)=>bool>)` shape. It used to be rejected as
// "non-whitelisted" because the reifier's whitelisted-Call receiver-type
// check re-derived the receiver's type outside the generic method's E->User
// substitution context; `reifyLambda` now takes that substitution so a
// whitelisted call inside a generic-parameter-typed lambda resolves the same
// as inside a concrete-class-typed one.
class User { int age; bool active; string name;
    new User(int a, bool ac, string n) { age = a; active = ac; name = n; } }

string dv(string | int | float | bool | None v) {
    match (v) {
        string => { return "str:" + v; }
        int    => { return "int:" + v.toString(); }
        float  => { return "float:" + v.toString(); }
        bool   => { return "bool:" + v.toString(); }
        else   => { return "none"; }
    }
}

string joinPath(Array<string> p) {
    string s = "";
    int i = 0;
    while (i < p.length()) { if (i > 0) { s = s + "."; } s = s + p[i]; i = i + 1; }
    return s;
}

string dumpArgs(Array<expr::Node> a) {
    string s = "";
    int i = 0;
    while (i < a.length()) { if (i > 0) { s = s + ","; } s = s + dump(a[i]); i = i + 1; }
    return s;
}

string dump(expr::Node n) {
    match (n) {
        expr::Bin    => { return "Bin(" + n.op + "," + dump(n.l) + "," + dump(n.r) + ")"; }
        expr::Un     => { return "Un(" + n.op + "," + dump(n.e) + ")"; }
        expr::Field  => { return "Field(" + joinPath(n.path) + ")"; }
        expr::Lit    => { return "Lit(" + dv(n.v) + ")"; }
        expr::Bind   => { return "Bind(" + n.slot.toString() + ")"; }
        expr::Call   => { return "Call(" + n.name + "," + dump(n.recv) + ",[" + dumpArgs(n.args) + "])"; }
        expr::Assign => { return "Assign(" + dump(n.target) + "," + dump(n.value) + ")"; }
        else         => { return "Node"; }
    }
}

string dumpBinds(Array<string | int | float | bool | None> b) {
    string s = "";
    int i = 0;
    while (i < b.length()) { if (i > 0) { s = s + ","; } s = s + dv(b[i]); i = i + 1; }
    return s;
}

void dumpSite(string label, expr::Node tree, Array<string | int | float | bool | None> binds, int site) {
    console.writeln(label + ":" + dump(tree));
    console.writeln(label + "binds:binds=[" + dumpBinds(binds) + "]");
    console.writeln(label + "site:siteId=" + site.toString());
}

class Query<E> {
    Array<expr::Node> wheres;
    Array<int> whereSites;
    expr::Node? setExpr;
    new Query() { wheres = []; whereSites = []; setExpr = None; }

    Query<E> where(expr::Expr<(E)=>bool> e) {
        wheres = wheres.add(e.tree);
        whereSites = whereSites.add(e.siteId);
        return this;
    }
    Query<E> set(expr::Expr<(E)=>int> e) {
        setExpr = e.tree;
        return this;
    }
    string renderWhere() {
        string s = "";
        int i = 0;
        while (i < wheres.length()) {
            if (i > 0) { s = s + " AND "; }
            s = s + dump(wheres[i]);
            i = i + 1;
        }
        return s;
    }
    string renderSites() {
        string s = "";
        int i = 0;
        while (i < whereSites.length()) {
            if (i > 0) { s = s + ","; }
            s = s + whereSites[i].toString();
            i = i + 1;
        }
        return s;
    }
    string renderSet() {
        match (setExpr) {
            expr::Node => { return dump(setExpr); }
            else => { return "(none)"; }
        }
    }
}

// Fluent-call position, two distinct .where sites: a plain comparison, then
// the ORM headline example's whitelisted-Call-inside-generic-lambda shape.
Query<User> q = Query();
q = q.where((u) => u.age > 18);
q = q.where((u) => u.active && u.name.like("A%"));

console.writeln("where=" + q.renderWhere());
console.writeln("sites=" + q.renderSites());

// .set() — the Expr<(E)=>int> shape.
Query<User> q2 = Query();
q2 = q2.set((u) => u.age + 1);
console.writeln("set=" + q2.renderSet());
