// LA-31 Stage 3 §4 — differential corpus: every whitelisted Call op
// (like/ilike/startsWith/endsWith/contains-string/contains-array).
class Rec { string name; new Rec(string n) { name = n; } }

// ---- expr::eval — reference tree interpreter (doc 01 §3.1, verbatim copy) ----
bool evalTruth(string | int | float | bool | None v) {
    match (v) {
        bool => { return v; }
        else => { return false; }
    }
}

string asStr(string | int | float | bool | None v) {
    match (v) {
        string => { return v; }
        else   => { return ""; }
    }
}

bool dbEq(string | int | float | bool | None a, string | int | float | bool | None b) {
    match (a) {
        None => { match (b) { None => { return true; }  else => { return false; } } }
        int  => { match (b) { int  => { return a == b; } else => { return false; } } }
        float=> { match (b) { float=> { return a == b; } else => { return false; } } }
        bool => { match (b) { bool => { return a == b; } else => { return false; } } }
        string => { match (b) { string => { return a == b; } else => { return false; } } }
    }
}

string | int | float | bool | None dbNum(string op,
        string | int | float | bool | None a, string | int | float | bool | None b) {
    match (a) {
        int => { match (b) { int => {
            int x = a; int y = b;
            if (op == "<")  return x < y;
            if (op == "<=") return x <= y;
            if (op == ">")  return x > y;
            if (op == ">=") return x >= y;
            if (op == "+")  return x + y;
            if (op == "-")  return x - y;
            if (op == "*")  return x * y;
            if (op == "/")  return x / y;
            if (op == "%")  return x % y;
        } else => { } } }
        float => { match (b) { float => {
            float x = a; float y = b;
            if (op == "<")  return x < y;
            if (op == "<=") return x <= y;
            if (op == ">")  return x > y;
            if (op == ">=") return x >= y;
            if (op == "+")  return x + y;
            if (op == "-")  return x - y;
            if (op == "*")  return x * y;
            if (op == "/")  return x / y;
        } else => { } } }
        string => { match (b) { string => {
            if (op == "+") return a + b;
        } else => { } } }
        else => { }
    }
    match (a) { None => { } else => { match (b) { None => { } else => {
        throw RuntimeException("expr::eval: bad operands for " + op); } } } }
    if (op == "<" || op == "<=" || op == ">" || op == ">=") return false;
    return None;
}

string | int | float | bool | None evalNode(
        expr::Node n,
        (Array<string>) => string | int | float | bool | None rec,
        Array<string | int | float | bool | None> binds,
        Array<string | int | float | bool | None> arrayBind0) {
    match (n) {
        expr::Field => { return rec(n.path); }
        expr::Lit   => { return n.v; }
        expr::Bind  => { return binds[n.slot]; }
        expr::Un    => {
            expr::Un u = n;
            string | int | float | bool | None inner = evalNode(u.e, rec, binds, arrayBind0);
            if (u.op == "!") return !evalTruth(inner);
            match (inner) {
                int   => { return 0 - inner; }
                float => { return 0.0 - inner; }
                else  => { return None; }
            }
        }
        expr::Bin   => {
            expr::Bin b = n;
            string | int | float | bool | None lv = evalNode(b.l, rec, binds, arrayBind0);
            string | int | float | bool | None rv = evalNode(b.r, rec, binds, arrayBind0);
            if (b.op == "&&") return evalTruth(lv) && evalTruth(rv);
            if (b.op == "||") return evalTruth(lv) || evalTruth(rv);
            if (b.op == "==") return dbEq(lv, rv);
            if (b.op == "!=") return !dbEq(lv, rv);
            return dbNum(b.op, lv, rv);
        }
        expr::Call  => {
            expr::Call c = n;
            if (c.name == "contains" && c.args.length() == 1) {
                match (c.recv) {
                    expr::Bind => {
                        string | int | float | bool | None needle =
                            evalNode(c.args[0], rec, binds, arrayBind0);
                        int k = 0;
                        while (k < arrayBind0.length()) {
                            if (dbEq(arrayBind0[k], needle)) return true;
                            k = k + 1;
                        }
                        return false;
                    }
                    else => { }
                }
            }
            string recvS = asStr(evalNode(c.recv, rec, binds, arrayBind0));
            string arg0S = asStr(evalNode(c.args[0], rec, binds, arrayBind0));
            if (c.name == "like")       return recvS.like(arg0S);
            if (c.name == "ilike")      return recvS.ilike(arg0S);
            if (c.name == "startsWith") return recvS.startsWith(arg0S);
            if (c.name == "endsWith")   return recvS.endsWith(arg0S);
            if (c.name == "contains")   return recvS.contains(arg0S);
            throw RuntimeException("expr::eval: non-whitelisted call " + c.name);
        }
        else => { throw RuntimeException("expr::eval: unhandled node"); }
    }
}
// ---- end expr::eval ----

(Array<string>) => string | int | float | bool | None recOf(Rec r) {
    return (path) => { if (path[0] == "name") return r.name; return None; };
}
Array<string | int | float | bool | None> noArr = [];

void cmp(string op, Rec r, expr::Expr<(Rec)=>bool> e) {
    bool fn = e.fn(r);
    bool ev = evalTruth(evalNode(e.tree, recOf(r), e.binds, noArr));
    console.writeln(op + ":" + fn.toString() + ":" + ev.toString());
}

Rec ada = Rec("Ada");
Rec bob = Rec("Bob");

expr::Expr<(Rec)=>bool> eLike  = (u) => u.name.like("A%");
expr::Expr<(Rec)=>bool> eIlike = (u) => u.name.ilike("a%");
expr::Expr<(Rec)=>bool> eSw    = (u) => u.name.startsWith("A");
expr::Expr<(Rec)=>bool> eEw    = (u) => u.name.endsWith("a");
expr::Expr<(Rec)=>bool> eCont  = (u) => u.name.contains("d");

cmp("like",  ada, eLike);  cmp("like",  bob, eLike);
cmp("ilike", ada, eIlike); cmp("ilike", bob, eIlike);
cmp("sw",    ada, eSw);    cmp("sw",    bob, eSw);
cmp("ew",    ada, eEw);    cmp("ew",    bob, eEw);
cmp("cont",  ada, eCont);  cmp("cont",  bob, eCont);

// Array-receiver contains (doc 01 §3.1): binds[slot]=None, arrayBind0 carries
// the real contents on the eval leg; the closure leg captures the array live.
class Tag { string tag; new Tag(string t) { tag = t; } }
(Array<string>) => string | int | float | bool | None recOfTag(Tag r) {
    return (path) => { if (path[0] == "tag") return r.tag; return None; };
}
Array<string> tags = [];
tags = tags.add("red");
tags = tags.add("blue");
Array<string | int | float | bool | None> tagArr = [];
tagArr = tagArr.add("red");
tagArr = tagArr.add("blue");

expr::Expr<(Tag)=>bool> eArrCont = (u) => tags.contains(u.tag);
Tag tRed = Tag("red");
Tag tGreen = Tag("green");
bool fn0 = eArrCont.fn(tRed);
bool ev0 = evalTruth(evalNode(eArrCont.tree, recOfTag(tRed), eArrCont.binds, tagArr));
console.writeln("arrcont:" + fn0.toString() + ":" + ev0.toString());
bool fn1 = eArrCont.fn(tGreen);
bool ev1 = evalTruth(evalNode(eArrCont.tree, recOfTag(tGreen), eArrCont.binds, tagArr));
console.writeln("arrcont:" + fn1.toString() + ":" + ev1.toString());
