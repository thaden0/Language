// Guarded GREEN (was XFAIL until known_bugs_2.md worktree-agent-a7c3e630889a1bf22-107): columnar IndexStore
// used to leak its VALUE operand exactly as the row-major dense_index_set.ext
// did (this is its columnar mirror) — `arr[i] = q` scatters q's fields across
// the columns but never freed q's standalone heap copy (~48B/iteration). The
// consuming lvrt_idxset_move now vfrees the dead copy at the store (the same
// fix as dense — techdesign-columnar-arrays.md §6.1's shared stretch goal,
// landed); this program is the leak-flatness floor for the columnar leg.
struct Pt { int x; int y; }
void run(int n) {
    Pt p;
    Array<Pt> pts;
    for (int i in 0..3) { pts = pts.add(p); }
    int sink = 0;
    for (int i in 1..n) {
        Pt q;
        q.x = i;
        q.y = i;
        pts[i - (i / 4) * 4] = q;   // columnar set: scatter in place, but q's copy leaks
        sink = sink + pts[0].x;
    }
    console.writeln(sink);
}
run(@N@);
