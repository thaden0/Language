uses Moby;
uses Moby::Dom;

// D02 M5 — the tier-equivalence / drift harness (design §6 M5, §7.1).
// ONE corpus file (every registry tag, every typed-attr shape) feeds all
// three tiers — the comptime import folds to an ordinary string literal by
// pass 2 (LA-20), so the same bytes drive:
//   A. `dom!(corpus)`                — comptime expansion (M4),
//   B. `buildMarkup(corpus, doc)`    — runtime string tier (M1–M3),
//   C. `FlexContainer(import(...))`  — asset/ctor tier (probe D-P7: import()
//                                      directly in a ctor argument),
// and the serializer must print byte-identical trees for all three (each
// tier builds against its own Document so ids cannot collide).

comptime string corpus = import("corpus.moby");

// the dom! holes' capture targets: a bare global (the full-fidelity D05
// path) and a typed (int) hole. Assigned in main, not at the declaration —
// top-level initializer order is a documented footgun.
string filename = "";
int build_count = 0;

void section(string s) { console.writeln("== " + s + " =="); }

// Recursive detach (the v1 teardown-test mechanic). Container.add attaches
// unconditionally — even into a detached tree — so the corpus's
// progress/spinner ctor-registered timers arm real process timers on build;
// without a run loop nothing cancels them and the process would outlive
// main. Detaching every node releases the bound tokens.
void teardown(IComponent c) {
    for (IComponent kid in c.__mobyChildren()) teardown(kid);
    c.__mobyDetach();
}

// a user component: Capitalized tag + pass-through setter at the dom! tier
class Gizmo : Component {
    string spin_ = "";
    void setSpin(string v) { spin_ = v; }
}

class DriftHost {
    // id-bound fields (the T06 field-binding rule: `id="x"` assigns
    // `this.x` alongside the registerId that __recordBuild performs)
    FlexContainer shell;
    Input name;
    Button okBtn;
    Button saveBtn;

    Array<string> perms = ["read", "write"];
    bool showHelp = true;
    int saves = 0;

    IComponent buildShared() { return dom!(corpus); }

    // dom!-tier-only surface: {expr} attrs, $for/$if/$else, on: handlers,
    // Capitalized user tags, binding holes over globals.
    IComponent buildDomOnly() {
        return dom!(`
            <flex width={Constraint::Fixed(30)} hidden={!this.showHelp}>
                build {{build_count}}
                $for p in this.perms {
                    <checkbox label={p}/>
                }
                $if this.showHelp {
                    <span>help</span>
                } $else {
                    <span>no help</span>
                }
                <button id="saveBtn" on:press={this.onSave}>Save</button>
                <Gizmo spin="3"/>
            </flex>
        `);
    }

    IComponent buildMulti() { return dom!(`<span>a</span><span>b</span>`); }

    void onSave() { saves = saves + 1; }
}

void main() {
    MobyApp app = MobyApp();
    Document docA = app.document();
    filename = "notes.txt";
    build_count = 7;

    DriftHost host = DriftHost();

    // tier A: dom! (expansion runs against the current Document). The trees
    // stay DETACHED throughout: the corpus spinner's ctor-registered timer
    // would arm on attach and keep the process alive after main returns
    // (the run-loop is out of scope here; serialization needs no attach).
    IComponent a = host.buildShared();

    // tier B: runtime parse of the same bytes
    Document docB = Document(app);
    docB.set("filename", "notes.txt");
    IComponent b = buildMarkup(corpus, docB);

    // tier C: asset/ctor tier. Probe D-P7 is RED — `import()` spliced
    // directly into a ctor argument is NOT comptime-folded (it reaches the
    // runtime prelude and throws LA-20); the design's documented fallback
    // is the T08 comptime-global shape (`corpus` above), cosmetic only.
    // The ctor is a fragment host: the corpus root is its first child.
    Document docC = Document(app);
    docC.set("filename", "notes.txt");
    __setCurrentDocument(docC);
    FlexContainer wrap = FlexContainer(corpus);
    __setCurrentDocument(docA);

    string sa = docA.outerMarkup(a);
    string sb = docB.outerMarkup(b);
    string sc = docC.outerMarkup(wrap.children()[0]);

    section("tier A serialized (dom!)");
    console.writeln(sa);
    section("tier equivalence (same markup -> same tree, all tiers)");
    console.writeln(sa == sb);
    console.writeln(sa == sc);

    section("id field bindings");
    console.writeln(host.name.placeholder);
    console.writeln(host.okBtn.label);
    console.writeln(host.shell.children().length());

    section("registry reverse-match (post-D03 rows)");
    console.writeln(registry().tagMatch(FlexContainer()));
    console.writeln(registry().tagMatch(Bar()));
    console.writeln(registry().tagMatch(Text()));

    section("dom!-only payload");
    IComponent d = host.buildDomOnly();
    console.writeln(docA.outerMarkup(d));
    // the $for's label={p} expr attrs (not serialized — {expr} has no meta row)
    if (d is Container) {
        Container dc = d;
        IComponent c1 = dc.children()[2];
        if (c1 is CheckBox) { CheckBox cb = c1; console.writeln(cb.label); }
        IComponent c2 = dc.children()[3];
        if (c2 is CheckBox) { CheckBox cb = c2; console.writeln(cb.label); }
    }
    host.saveBtn.fireKey(KeyEvent(KeyCode::Enter, std::charFromCode(0), 0));
    console.writeln(host.saves);

    section("fragment auto-wrap");
    IComponent m = host.buildMulti();
    console.writeln(m is FlexContainer);
    if (m is Container) { Container mc = m; console.writeln(mc.children().length()); }

    // ==================================================================
    // D08 M2 — drift harness tiers 2–4 (techdesign-08 §3)
    // ==================================================================

    // ---- tier 2: registry-coverage ----------------------------------------
    // Every D-C1 tag that has a nullary factory must be registered. Tags
    // noted as "deferred" (grid/list — no nullary factory) are excluded.
    // A missing tag fails the corpus: a new tag without a corpus line must
    // appear here first.
    section("tier-2 registry-coverage");
    Array<string> d1Tags = [
        "flex", "contentbar", "bar", "statusbar", "span", "text",
        "textarea", "input", "button", "checkbox", "radiogroup",
        "progress", "spinner", "table", "tree", "tabs", "split",
        "box", "menubar", "menu", "menuitem", "separator", "modal"
    ];
    bool tier2ok = true;
    for (string t in d1Tags) {
        if (!registry().has(t)) {
            console.writeln("MISSING: " + t);
            tier2ok = false;
        }
    }
    console.writeln(tier2ok);
    // Verify the corpus hit every tag (the drift invariant: every tag in the
    // registry must appear in corpus.moby at least once). We check by
    // building and querying back for each tag.
    DomNodeList all2 = DomNode(a, docA).queryAll("*");
    // Every tag we require must have been built at least once in tier A.
    // A quick sanity-check for representative tags:
    console.writeln(DomNode(a, docA).queryAll("flex").length() > 0);
    console.writeln(DomNode(a, docA).queryAll("span").length() > 0);
    console.writeln(DomNode(a, docA).queryAll("input").length() > 0);

    // ---- tier 3: ladder-coverage ------------------------------------------
    // Every tag's DomNode value/text/checked/enabled ladder row is tested.
    // A result of "NO THROW: tag.accessor" means the ladder is reachable;
    // "THROW: tag.accessor" means the accessor correctly throws on that tag.
    // We use a fresh Document tied to the existing app (no second MobyApp).
    section("tier-3 ladder");
    Document doc3 = Document(app);

    // Input: value, text, enabled
    Input inp3 = Input();
    doc3.__recordBuild(inp3, "input", [], []);
    inp3.setValue("hello");
    DomNode dinp3 = DomNode(inp3, doc3);
    console.writeln(dinp3.value());         // hello
    console.writeln(dinp3.text());          // hello
    console.writeln(dinp3.enabled());       // true
    inp3.setEnabled(false);
    console.writeln(dinp3.enabled());       // false

    // TextArea: value, text
    TextArea ta3 = TextArea();
    doc3.__recordBuild(ta3, "textarea", [], []);
    ta3.setText("world");
    DomNode dta3 = DomNode(ta3, doc3);
    console.writeln(dta3.value());          // world
    console.writeln(dta3.text());           // world

    // CheckBox: checked (both directions)
    CheckBox cb3 = CheckBox();
    doc3.__recordBuild(cb3, "checkbox", [], []);
    cb3.setChecked(true);
    DomNode dcb3 = DomNode(cb3, doc3);
    console.writeln(dcb3.checked());        // true
    dcb3.checked(false);
    console.writeln(dcb3.checked());        // false

    // Button: text, value (both read the label), enabled
    Button btn3 = Button();
    doc3.__recordBuild(btn3, "button", [], []);
    btn3.setLabel("Click");
    DomNode dbtn3 = DomNode(btn3, doc3);
    console.writeln(dbtn3.text());          // Click
    console.writeln(dbtn3.value());         // Click
    console.writeln(dbtn3.enabled());       // true

    // Text/span: text, value
    Text txt3 = Text();
    doc3.__recordBuild(txt3, "span", [], []);
    txt3.text("hello span");
    DomNode dtxt3 = DomNode(txt3, doc3);
    console.writeln(dtxt3.text());          // hello span
    console.writeln(dtxt3.value());         // hello span

    // Show/hide via the class (D-C6 hidden is semantic):
    dinp3.hide();
    console.writeln(inp3.hasClass("hidden"));    // true
    dinp3.show();
    console.writeln(inp3.hasClass("hidden"));    // false

    // ---- tier 4: serializer round-trip ------------------------------------
    // parse -> serialize -> parse: the two serializations must be identical
    // (D01 §5.1 guarantee). Uses a self-contained fixture with no binding
    // holes (holes expand to runtime values, not to the literal hole text,
    // so a re-parse of the serialized form necessarily differs — the round-
    // trip guarantee is for STATIC markup only).
    section("tier-4 round-trip");
    string rtMarkup = "<flex id=\"rt\"><span>hello</span><input value=\"world\"/><checkbox checked=\"true\"/></flex>";
    Document docR1 = Document(app);
    IComponent rt1 = buildMarkup(rtMarkup, docR1);
    string ser1 = docR1.outerMarkup(rt1);
    Document docR2 = Document(app);
    IComponent rt2 = buildMarkup(ser1, docR2);
    string ser2 = docR2.outerMarkup(rt2);
    console.writeln(ser1 == ser2);          // true
    teardown(rt1); teardown(rt2);

    teardown(a); teardown(b); teardown(wrap); teardown(d); teardown(m);
}
