uses Moby;
uses Moby::Dom;

void section(string s) { console.writeln("== " + s + " =="); }

void tryBuild(string label, string src, Document doc) {
    try {
        buildMarkupFragment(src, doc);
        console.writeln(label + ": NO THROW");
    } catch (MobyException e) {
        console.writeln(label + ":");
        console.writeln(e.message);
    }
}

void main() {
    MobyApp app = MobyApp();
    Document doc = app.document();
    doc.set("filename", "notes.txt");

    string src = "<flex id=\"main\" class=\"panel\">"
        + "<menu id=\"file-menu\" class=\"bar\">"
        + "<button id=\"open\" action=\"open\" width=\"10\">Open</button>"
        + "<button id=\"save\">Save</button>"
        + "</menu>"
        + "<input id=\"name\" placeholder=\"your name\" maxLength=\"20\"/>"
        + "<checkbox id=\"agree\" checked=\"true\">Agree</checkbox>"
        + "<span>Editing {{filename}}</span>"
        + "</flex>";

    IComponent root = buildMarkup(src, doc);
    app.add(root);

    section("structure");
    console.writeln(app.queryAll("button").length());      // 2
    console.writeln(app.queryAll("menu button").length()); // 2
    console.writeln(app.queryAll("#file-menu > button").length()); // 2
    console.writeln(app.query("#open").text());            // Open
    console.writeln(app.query("#open").attr("action"));    // open
    console.writeln(app.query("#name").value());           // (empty placeholder-only)
    console.writeln(app.query("#agree").checked());        // true
    console.writeln(app.query("#agree").text());           // Agree

    section("hole");
    // {{filename}} resolved once against the store at build time
    console.writeln(app.queryAll("#main span").length() >= 1); // true
    console.writeln(app.query("#file-menu").children().length()); // 2

    section("serializer");
    console.writeln(app.query("#file-menu").outerMarkup());

    section("registerTag");
    registerTag("gizmo",
        () => Button(),
        (c) => false,
        (c, name, value) => { if (name == "spin") { return true; } return false; });
    IComponent g = buildMarkup("<gizmo id=\"g1\" spin=\"3\">Go</gizmo>", doc);
    app.add(g);
    console.writeln(app.query("#g1").text());              // Go
    console.writeln(doc.tagOf(g));                        // gizmo (via node meta)

    section("errors");
    tryBuild("unclosed", "<menu><button>x</menu>", doc);
    tryBuild("mismatch", "<menu></flex>", doc);
    tryBuild("unknown-tag", "<nope/>", doc);
    tryBuild("bad-int", "<flex width=\"wide\"></flex>", doc);
    tryBuild("theme", "<flex theme=\"dark\"></flex>", doc);
    tryBuild("empty", "   ", doc);
}
