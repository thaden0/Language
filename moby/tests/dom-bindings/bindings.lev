uses Moby;
uses Moby::Dom;

// Moby DOM — techdesign-05 corpus: the `{{…}}` pull-sweep. A pure-logic test
// (no run loop). The sweep is driven straight through `doc.__sweepBindings()` —
// the exact call MobyApp.renderFrame makes at frame start (D01 §3 / app.lev),
// so this is deterministic with zero timing sensitivity (D05 §4). Covers: the
// dom! full-fidelity path (a bare global write, no observer registration),
// typed holes + the `text` overload family (D-P3), the runtime tier's three
// resolutions (expose / store / miss), leaf concat, exception containment,
// diff no-op, tombstoning + compaction.

void section(string s) { console.writeln("== " + s + " =="); }

// A node's display text without leaning on any Document internals.
string disp(IComponent c) {
    if (c is Text)   { Text t = c;   return t.text; }
    if (c is Button) { Button b = c; return b.label; }
    return "?";
}

// dom!-tier hole capture targets: bare globals (the full-fidelity path). Set in
// main, never at the declaration (top-level init order is a documented footgun).
string        filename  = "";
int           counter   = 0;
string | None maybeName = None;

// exposed-getter capture target; `read()` throws when armed (containment test).
class Boom {
    bool   armed = false;
    string val   = "ok";
    string read() { if (armed) throw MobyException("boom"); return val; }
}
Boom boom = Boom();

// expose() capture target (the live app-supplied closure route).
class Clock { string now = "t0"; }
Clock clock = Clock();

// dom! holes over globals (ident holes). A hole placed as a fragment child of a
// container becomes its OWN bound span (the emitter's `bindText` path); the
// closure reads the global directly, so a bare write updates it on the sweep.
// (A hole that is the whole text CONTENT of a leaf like `<span>` is one-shot at
// the dom! tier — a landed D02 decision; the runtime tier binds those instead.)
class Host {
    IComponent nameBox()  { return dom!(`<flex>{{filename}}</flex>`); }
    IComponent countBox() { return dom!(`<flex>{{counter}}</flex>`); }
    IComponent maybeBox() { return dom!(`<flex>{{maybeName}}</flex>`); }
}

// The bound span the emitter puts inside such a container.
IComponent holeSpan(IComponent container) => container.__mobyChildren()[0];

void main() {
    MobyApp app = MobyApp();
    Document doc = app.document();
    Host host = Host();

    // ======================================================================
    // The headline: `<span>{{filename}}</span>` + a bare `filename = …` write
    // updates the span on the next sweep. No expose, no store, no signal type.
    section("dom!-global");
    filename = "notes.txt";
    IComponent sBox = host.nameBox();
    app.add(sBox);
    IComponent s = holeSpan(sBox);
    console.writeln(disp(s));                 // notes.txt (initial render at build)
    filename = "renamed.md";
    console.writeln(disp(s));                 // notes.txt (pull, not push: not yet swept)
    doc.__sweepBindings();
    console.writeln(disp(s));                 // renamed.md (swept)
    console.writeln(doc.__sweepDirty());      // true (the sweep applied a change)
    doc.__sweepBindings();
    console.writeln(doc.__sweepDirty());      // false (no-op diff -> zero damage)

    // ======================================================================
    // Typed holes in situ: int and string|None run through the `text` family.
    section("typed-holes");
    counter = 1;
    IComponent nBox = host.countBox();
    app.add(nBox);
    IComponent n = holeSpan(nBox);
    console.writeln(disp(n));                 // 1
    counter = 42;
    doc.__sweepBindings();
    console.writeln(disp(n));                 // 42

    IComponent mbBox = host.maybeBox();
    app.add(mbBox);
    IComponent mb = holeSpan(mbBox);
    console.writeln("[" + disp(mb) + "]");    // [] (None renders "")
    maybeName = "here";
    doc.__sweepBindings();
    console.writeln(disp(mb));                // here

    // ======================================================================
    // The overload family directly (D-P3 matrix, string|None both states).
    section("text-overloads");
    string | None non = None;
    string | None som = "x";
    float ff = 2.5;
    char cc = 'Z';
    console.writeln(Moby::Dom::text("str"));            // str
    console.writeln("[" + Moby::Dom::text(non) + "]");  // []
    console.writeln(Moby::Dom::text(som));              // x
    console.writeln(Moby::Dom::text(7));                // 7
    console.writeln(Moby::Dom::text(ff));               // 2.500000
    console.writeln(Moby::Dom::text(true));             // true
    console.writeln(Moby::Dom::text(cc));               // Z

    // ======================================================================
    // Runtime tier — the store route: doc.set(...) is picked up by the sweep.
    section("runtime-store");
    doc.set("title", "Draft");
    IComponent rt = buildMarkup("<flex>{{title}}</flex>", doc);
    app.add(rt);
    IComponent titleSpan = rt.__mobyChildren()[0];
    console.writeln(disp(titleSpan));         // Draft (initial)
    doc.set("title", "Final");
    doc.__sweepBindings();
    console.writeln(disp(titleSpan));         // Final

    // ======================================================================
    // Runtime tier — a multi-piece leaf run concatenates into ONE binding.
    section("leaf-concat");
    doc.set("who", "Ada");
    IComponent btn = buildMarkup("<button>Hi {{who}}</button>", doc);
    app.add(btn);
    console.writeln(disp(btn));               // Hi Ada
    doc.set("who", "Bob");
    doc.__sweepBindings();
    console.writeln(disp(btn));               // Hi Bob

    // ======================================================================
    // Runtime tier — the expose route (checked before the store, §3).
    section("runtime-expose");
    doc.expose("clock", () => clock.now);
    IComponent ce = buildMarkup("<flex>{{clock}}</flex>", doc);
    app.add(ce);
    IComponent clockSpan = ce.__mobyChildren()[0];
    console.writeln(disp(clockSpan));         // t0 (initial)
    clock.now = "t1";
    doc.__sweepBindings();
    console.writeln(disp(clockSpan));         // t1

    // ======================================================================
    // Runtime tier — a miss: renders "" once + exactly one log line, quiet
    // thereafter (the log-once degradation).
    section("runtime-miss");
    int logsBefore = Moby::logHistory().length();
    IComponent miss = buildMarkup("<flex>{{ghost}}</flex>", doc);
    app.add(miss);
    IComponent ghostSpan = miss.__mobyChildren()[0];
    console.writeln("[" + disp(ghostSpan) + "]");            // [] (empty render)
    int logsAfterBuild = Moby::logHistory().length();
    console.writeln(logsAfterBuild - logsBefore);            // 1 (logged once, at build)
    doc.__sweepBindings();
    doc.__sweepBindings();
    console.writeln(Moby::logHistory().length() - logsAfterBuild);  // 0 (no re-logging)

    // ======================================================================
    // Exception containment: a throwing getter is caught/logged/counted and the
    // binding keeps its last good value (the T03 rule).
    section("getter-throws");
    boom.val = "ok";
    doc.expose("risky", () => boom.read());
    IComponent rk = buildMarkup("<flex>{{risky}}</flex>", doc);
    app.add(rk);
    IComponent riskySpan = rk.__mobyChildren()[0];
    console.writeln(disp(riskySpan));         // ok (initial, unarmed)
    int faultsBefore = Moby::handlerErrorCount();
    boom.armed = true;
    doc.__sweepBindings();
    console.writeln(disp(riskySpan));         // ok (last good value; throw contained)
    console.writeln(Moby::handlerErrorCount() - faultsBefore);  // 1
    boom.armed = false;
    boom.val = "fixed";
    doc.__sweepBindings();
    console.writeln(disp(riskySpan));         // fixed (recovered)

    // ======================================================================
    // refresh(): the public escape hatch — sweep now, no run loop needed.
    section("refresh");
    filename = "via-refresh";
    doc.refresh();
    console.writeln(disp(s));                 // via-refresh

    // ======================================================================
    // Tombstoning + compaction at D-P10's threshold (25% dead AND >=64 dead).
    // A separate Document so the count is not diluted by the bindings above.
    section("churn");
    Document churn = Document(app);
    FlexContainer churnRoot = FlexContainer();
    app.add(churnRoot);
    int nBindings = 64;
    for (int i in 0..nBindings - 1) {
        Text t = Text();
        churnRoot.add(t);
        churn.__recordBuild(t, "span", [], []);
        bindText(churn, t, "{{k}}", () => "v");
    }
    console.writeln(churn.__bindingCount());      // 64
    churn.__sweepBindings();
    console.writeln(churn.__liveBindingCount());  // 64 (all reach the root)
    churnRoot.setParent(None);                    // detach the whole subtree
    churn.__sweepBindings();                       // sweep-while-detached tombstones + compacts
    console.writeln(churn.__bindingCount());       // 0 (dead entries reclaimed)
    console.writeln(churn.__liveBindingCount());   // 0

    // ======================================================================
    // Diff no-op is idempotent — exactly how a dom! hole over a T11 reactive
    // field stays harmless (§5): the second application is absorbed by the diff.
    section("idempotent");
    counter = 100;
    IComponent d1Box = host.countBox();
    IComponent d2Box = host.countBox();
    app.add(d1Box); app.add(d2Box);
    IComponent d1 = holeSpan(d1Box);
    IComponent d2 = holeSpan(d2Box);
    doc.__sweepBindings();
    console.writeln(disp(d1) + "/" + disp(d2));    // 100/100
    doc.__sweepBindings();
    console.writeln(doc.__sweepDirty());           // false (nothing left to re-apply)

    console.writeln("done");
}
