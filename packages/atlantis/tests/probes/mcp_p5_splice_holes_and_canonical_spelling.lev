// T7-P5: bare (unquoted) `$m.name`, `$C.name`, `$p.type` holes as string
// VALUES (constructor arguments, not string-literal interpolation -- §mcp_p4
// found the quoted-interpolation form the design text used does NOT
// substitute), plus the canonical spelling `meta::Param.type`/
// `meta::Field.type` produce for a struct nested two namespaces deep. Pins
// the SchemaRegistry key spelling (§4.3).
namespace App {
    namespace Dto {
        struct AddArgs { int a; int b; }
    }
}
namespace Probe {
    interface IMarker { }
    attribute Tag { }
    rule tagRule {
        match @Tag on method m in class C : IMarker
        inject `string __report() =>
            $C.name + "." + $m.name + "(" +
            [ $for p in m.params : $p.type ].joinToString(",") + ")";`
            at member of C
    }
}
uses Probe;
uses App::Dto;

class Svc : Probe::IMarker {
    @Tag
    int addPair(AddArgs args, int extra) => extra;
}

console.writeln(Svc().__report());
