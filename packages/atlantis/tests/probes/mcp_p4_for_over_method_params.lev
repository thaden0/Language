// T7-P4: `$for p in m.params : F("$p.name", "$p.type")` inside a
// METHOD-subject rule -- docs show `$for` over C.fields; this proves it
// works identically over a bound method's `m.params` (meta::Param has the
// same name/type shape as meta::Field). Gates the ParamSpec descriptor list
// every arity of §3.3's rule builds.
//
// (Incidental finding, unrelated to rules: a top-level `for (...)` statement
// does not parse outside a function body -- "expected expression" at `for`.
// Every loop below is inside `run()`, matching the app.lev corpus convention.)
namespace Probe {
    struct PSpec {
        string name; string type;
        new PSpec(string name, string type) { this.name = name; this.type = type; }
        string render() => name + ":" + type;
    }
    interface IMarker { }
    attribute Tag { }
    rule tagRule {
        match @Tag on method m in class C : IMarker
        inject `this.specs = this.specs.add(
            [ $for p in m.params : Probe::PSpec($p.name, $p.type) ]);`
            at bottom of C.constructor
    }
}
uses Probe;

class Svc : Probe::IMarker {
    Array<Array<Probe::PSpec>> specs = [];
    @Tag
    int addPair(int a, string b) => a;
    @Tag
    int noArgs() => 0;
}

void run() {
    Svc svc = Svc();
    Array<string> rendered = [];
    for (Probe::PSpec p in svc.specs.at(0)) { rendered = rendered.add(p.render()); }
    console.writeln(rendered.joinToString(","));
    console.writeln(svc.specs.at(1).length().toString());
}
run();
