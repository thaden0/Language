// T7-P2: rule injects a zero-arg labeled ctor with an EMPTY body
// (`new Empty() { }`) into a struct; construct via it; read every field's
// default value. Gates §4.1's `Empty()` injection (the receiver `schemaJson()`
// needs when no instance exists yet).
namespace Probe {
    interface IMarker { }
    attribute Mk { }
    rule mkRule {
        match @Mk on struct C
        where C.hasBase("IMarker")
        inject `new Empty() { }` at member of C
    }
}
uses Probe;

@Mk
struct Widget : Probe::IMarker {
    int a;
    string s;
    bool b;
    float f;
    Array<int> xs;
}

Widget w = Widget::Empty();
console.writeln(w.a.toString() + "|" + w.s + "|" + w.b.toString() + "|" +
    w.f.toString() + "|" + w.xs.length().toString());
