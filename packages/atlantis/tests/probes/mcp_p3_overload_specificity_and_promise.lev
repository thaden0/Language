// T7-P3: `content(string)` (concrete) vs `content<R>(R)` (generic fallback) --
// most-specific overload must win for string; the generic must still cover a
// toJson()-bearing struct. Also: awaiting a Promise<T> then passing the
// resolved T into an overloaded call. Gates §3.3's `content()` helper family
// (used by the hand-written dispatch adapters after T7-P1's fallback, §3.5
// rung 3 -- ordinary concrete-argument overload resolution, not generic-
// from-lambda-argument, so unaffected by the T7-P1 gap).
namespace Probe {
    interface IJ { string toJson(); }
    string content(string s) => "str:" + s;
    string content<R>(R r) => "generic:" + r.toJson();
}
uses Probe;

class Widget : Probe::IJ {
    string toJson() => "{widget}";
}

Promise<string> mkPromise() {
    Promise<string> p = Promise();
    p.resolve("ps");
    return p;
}

void run() {
    console.writeln(Probe::content("hello"));
    console.writeln(Probe::content(Widget()));
    string awaited = await mkPromise();
    console.writeln(Probe::content(awaited));
}
await run();
