// T7-P6: two INDEPENDENT rules matching the SAME `@Serializable`-shaped
// attribute usage on one struct, both firing and stacking their injections.
// Gates §1's "two rules matching @Serializable on one struct" split (Track
// 03 owns toJson/FromJson; Track 07 owns schemaJson/Empty) -- per the
// design's own commissioning note (§1/§4.1), Track 07's rule lives in the
// SAME `namespace Atlantis` the attribute is declared in (not a nested
// namespace) specifically so this single-file, single-`uses` shape holds;
// a rule declared in a DIFFERENT namespace than its matched attribute was
// tried and does NOT fire ("attribute matched no imported rule") even with
// that namespace `uses`-imported at file scope -- confirming the design's
// namespace choice is load-bearing, not stylistic.
namespace Marker {
    interface ISerializable { }
    attribute Serializable { }
    rule ownerARule {
        match @Serializable on struct C
        where C.hasBase("ISerializable")
        inject `string fromA() => "A";` at member of C
    }
    rule ownerBRule {
        match @Serializable on struct C
        where C.hasBase("ISerializable")
        inject `string fromB() => "B";` at member of C
    }
}
uses Marker;

@Serializable
struct Widget : ISerializable {
    int x;
}

Widget w = Widget();
console.writeln(w.fromA() + w.fromB());
