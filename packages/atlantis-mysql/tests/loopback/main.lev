// atlantis-mysql — end-to-end loopback acceptance (design §7.1 "recording proxy"
// idea, inverted: an in-language fake MySQL 8 server scripts the wire, the REAL
// Driver drives it over a loopback socket. Validates connect+auth+SET NAMES,
// COM_QUERY text protocol with typed mapping, prepared INSERT (params ->
// ExecResult), prepared SELECT (binary rows), transactions, the duplicate-key
// typed error path, and PING — on oracle / IR / LLVM.
uses MySql;
uses MySql::Wire;
uses MySql::FieldType;
uses Atlantis::Data;

// ---------- packet builders (server side) ----------

string colDef(string name, int type, int flags) {
    StringBuilder sb = StringBuilder();
    sb << writeLenStr("def");
    sb << writeLenStr("");
    sb << writeLenStr("t");
    sb << writeLenStr("t");
    sb << writeLenStr(name);
    sb << writeLenStr(name);
    sb << writeLenenc(0x0c);
    sb << wU16(45);
    sb << wU32(255);
    sb << wU8(type);
    sb << wU16(flags);
    sb << wU8(0);
    sb << wU16(0);
    return sb.toString();
}
string okPacket(int affected, int lastInsert, int status) {
    StringBuilder sb = StringBuilder();
    sb << wU8(0x00);
    sb << writeLenenc(affected);
    sb << writeLenenc(lastInsert);
    sb << wU16(status);
    sb << wU16(0);
    return sb.toString();
}
string eofPacket(int status) {
    StringBuilder sb = StringBuilder();
    sb << wU8(0xFE);
    sb << wU16(0);
    sb << wU16(status);
    return sb.toString();
}
string errPacket(int errno, string sqlstate, string msg) {
    StringBuilder sb = StringBuilder();
    sb << wU8(0xFF);
    sb << wU16(errno);
    sb << std::byteToString(0x23);
    sb << sqlstate;
    sb << msg;
    return sb.toString();
}
string textRow(Array<string | None> cells) {
    StringBuilder sb = StringBuilder();
    for (string | None c in cells) {
        match (c) {
            None   => { sb << std::byteToString(0xFB); }
            string => { sb << writeLenStr(c); }
        }
    }
    return sb.toString();
}
string prepareOk(int stmtId, int numColumns, int numParams) {
    StringBuilder sb = StringBuilder();
    sb << wU8(0x00);
    sb << wU32(stmtId);
    sb << wU16(numColumns);
    sb << wU16(numParams);
    sb << wU8(0x00);
    sb << wU16(0);
    return sb.toString();
}
// binary row for one LONGLONG column
string binRowLongLong(int val) {
    StringBuilder sb = StringBuilder();
    sb << wU8(0x00);            // header
    sb << wU8(0x00);            // null bitmap: (1 + 2 + 7)/8 = 1 byte, no nulls
    sb << wU64(val);           // 8-byte LE
    return sb.toString();
}
string handshake(string nonce20) {
    int caps = 0x0200 | 0x00080000 | 0x00008000 | 0x0008 | 0x2000 | 0x00200000;
    int lower = caps & 0xFFFF;
    int upper = (caps >> 16) & 0xFFFF;
    StringBuilder sb = StringBuilder();
    sb << wU8(10);
    sb << "8.0.32"; sb << std::byteToString(0);
    sb << wU32(1);
    sb << nonce20.subStr(0, 8);
    sb << std::byteToString(0);
    sb << wU16(lower);
    sb << wU8(45);
    sb << wU16(2);
    sb << wU16(upper);
    sb << wU8(21);
    sb << zeros(10);
    sb << nonce20.subStr(8, 12); sb << std::byteToString(0);
    sb << "mysql_native_password"; sb << std::byteToString(0);
    return sb.toString();
}

// ---------- fake server ----------

class FakeServer {
    TcpListener listener;
    bool authed;
    MySql::PacketAssembler asm;
    TcpStream client;

    new FakeServer(int port) {
        this.listener = TcpListener(port);
        this.authed = false;
        this.asm = MySql::PacketAssembler((s, p) => { });
        this.client = TcpStream(0 - 1);
    }
    bool ok() => this.listener.ok();

    void start() {
        FakeServer self = this;
        this.listener.connections((c) => self.onConnect(c));
    }
    void stop() { this.listener.stop(); }

    void onConnect(TcpStream c) {
        FakeServer self = this;
        this.client = c;
        this.authed = false;
        this.asm = MySql::PacketAssembler((s, p) => self.onPacket(s, p));
        c.onData((chunk) => self.asm.feed(chunk));
        // send HandshakeV10 (seq 0)
        string nonce = "";
        int i = 1; while (i <= 20) { nonce = nonce + std::byteToString(i); i = i + 1; }
        this.send1(handshake(nonce), 0);
    }

    // one logical payload
    void send1(string payload, int seq) {
        this.client.send(MySql::Framing::encode(payload, seq));
    }
    // several logical payloads, seq auto-incrementing from start
    void sendMany(Array<string> payloads, int startSeq) {
        StringBuilder sb = StringBuilder();
        int s = startSeq;
        for (string pl in payloads) {
            sb << MySql::Framing::encode(pl, s);
            s = (s + MySql::Framing::packetCount(pl.length())) & 0xFF;
        }
        this.client.send(sb.toString());
    }

    void onPacket(int seq, string payload) {
        int reply = (seq + 1) & 0xFF;
        if (!this.authed) {                 // this is HandshakeResponse41
            this.authed = true;
            this.send1(okPacket(0, 0, 2), reply);
            return;
        }
        int cmd = payload.byteAt(0);
        string arg = payload.subStr(1, payload.length() - 1);
        if (cmd == 0x03) { this.onQuery(arg, reply); return; }
        if (cmd == 0x16) { this.onPrepare(arg, reply); return; }
        if (cmd == 0x17) { this.onExecute(payload, reply); return; }
        if (cmd == 0x0E) { this.send1(okPacket(0, 0, 2), reply); return; }   // PING
        if (cmd == 0x01) { this.client.close(); return; }                    // QUIT
        if (cmd == 0x19) { return; }                                         // STMT_CLOSE: no reply
        this.send1(okPacket(0, 0, 2), reply);
    }

    void onQuery(string sql, int reply) {
        if (sql == "SELECT typed") {
            Array<string> pk = [];
            pk = pk.add(writeLenenc(5));                                  // column count
            pk = pk.add(colDef("id", LONG, 0));
            pk = pk.add(colDef("name", VAR_STRING, 0));
            pk = pk.add(colDef("flag", TINY, 0));
            pk = pk.add(colDef("ratio", DOUBLE, 0));
            pk = pk.add(colDef("note", VAR_STRING, 0));
            pk = pk.add(eofPacket(2));                                    // end of columns
            Array<string | None> r1 = [];
            r1 = r1.add("42"); r1 = r1.add("alice"); r1 = r1.add("1");
            r1 = r1.add("3.5"); r1 = r1.add(None);
            pk = pk.add(textRow(r1));
            pk = pk.add(eofPacket(2));                                    // end of rows
            this.sendMany(pk, reply);
            return;
        }
        if (sql == "FAILDUP") {
            this.send1(errPacket(1062, "23000", "Duplicate entry 'x' for key 'PRIMARY'"), reply);
            return;
        }
        if (sql == "BEGIN") { this.send1(okPacket(0, 0, 3), reply); return; }   // IN_TRANS|autocommit
        // SET NAMES, COMMIT, ROLLBACK, everything else
        this.send1(okPacket(0, 0, 2), reply);
    }

    void onPrepare(string sql, int reply) {
        if (sql.length() >= 6 && sql.subStr(0, 6) == "SELECT") {
            Array<string> pk = [];
            pk = pk.add(prepareOk(10, 1, 1));            // stmtId 10, 1 col, 1 param
            pk = pk.add(colDef("?", LONG, 0));  // param def
            pk = pk.add(eofPacket(2));
            pk = pk.add(colDef("id", LONGLONG, 0)); // column def
            pk = pk.add(eofPacket(2));
            this.sendMany(pk, reply);
            return;
        }
        // INSERT with 2 params, no result columns
        Array<string> pk = [];
        pk = pk.add(prepareOk(11, 0, 2));
        pk = pk.add(colDef("?", LONG, 0));
        pk = pk.add(colDef("?", VAR_STRING, 0));
        pk = pk.add(eofPacket(2));
        this.sendMany(pk, reply);
    }

    void onExecute(string payload, int reply) {
        int stmtId = u32(payload, 1);
        if (stmtId == 10) {
            Array<string> pk = [];
            pk = pk.add(writeLenenc(1));
            pk = pk.add(colDef("id", LONGLONG, 0));
            pk = pk.add(eofPacket(2));
            pk = pk.add(binRowLongLong(99));
            pk = pk.add(eofPacket(2));
            this.sendMany(pk, reply);
            return;
        }
        this.send1(okPacket(1, 7, 2), reply);            // INSERT execute -> OK
    }
}

// ---------- client scenario ----------

string dv(string | int | float | bool | None v) {
    match (v) {
        int => { return "int:" + v.toString(); }
        float => { return "flt:" + v.toString(); }
        string => { return "str:" + v; }
        bool => { return "bool:" + v.toString(); }
        None => { return "null"; }
    }
}

Promise<void> runClient() {
    Driver drv = Driver();
    DbConfig cfg = DbConfig("127.0.0.1", 13306, "atlantis", "atlantis-pass", "atlantis_test");
    IDbConnection conn = await drv.connect(cfg);
    console.writeln("[connect] READY");

    // text SELECT with typed mapping
    Array<string | int | float | bool | None> none = [];
    ResultSet rs = await conn.query("SELECT typed", none);
    console.writeln("[select] cols=" + rs.columns.joinToString(","));
    Row row = rs.rows.first();
    console.writeln("[select] id=" + dv(row.byName("id"))
        + " name=" + dv(row.byName("name"))
        + " flag=" + dv(row.byName("flag"))
        + " ratio=" + dv(row.byName("ratio"))
        + " note=" + dv(row.byName("note")));

    // prepared INSERT (params -> ExecResult)
    Array<string | int | float | bool | None> ip = [];
    ip = ip.add(1); ip = ip.add("a");
    ExecResult er = await conn.execute("INSERT INTO t VALUES (?, ?)", ip);
    console.writeln("[insert] affected=" + er.affectedRows.toString() + " lastId=" + er.lastInsertId.toString());

    // prepared SELECT (binary rows)
    Array<string | int | float | bool | None> sp = [];
    sp = sp.add(1);
    ResultSet rs2 = await conn.query("SELECT id FROM t WHERE id = ?", sp);
    console.writeln("[prepared-select] id=" + dv(rs2.rows.first().byName("id")));

    // transaction commit
    ITransaction tx = await conn.begin();
    Array<string | int | float | bool | None> tp = [];
    tp = tp.add(2); tp = tp.add("b");
    ExecResult er2 = await conn.execute("INSERT INTO t VALUES (?, ?)", tp);
    await tx.commit();
    console.writeln("[tx] committed, affected=" + er2.affectedRows.toString());

    // duplicate-key typed error path
    try {
        ResultSet bad = await conn.query("FAILDUP", none);
        console.writeln("[dup] NO ERROR (bug)");
    } catch (IDuplicateKeyException e) {
        console.writeln("[dup] caught IDuplicateKeyException errno=" + e.errno.toString() + " state=" + e.sqlstate);
    }

    // ping
    bool alive = await conn.ping();
    console.writeln("[ping] alive=" + alive.toString());

    conn.close();
    Promise<void> done = Promise();
    done.resolve(None);
    return done;
}

void main() {
    FakeServer srv = FakeServer(13306);
    if (!srv.ok()) { console.writeln("listener failed"); return; }
    srv.start();
    await runClient();
    srv.stop();
    console.writeln("[done]");
}
